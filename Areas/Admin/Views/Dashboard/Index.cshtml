@using SaleStore.Models
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stat Cards -->
<div class="row g-4 mb-5">

    <!-- Total Revenue -->
    <div class="col-12 col-md-6 col-lg-4 col-xl-3">
        <div class="card text-white shadow-sm bg-gradient-dashboard-revenue">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center justify-content-center rounded-3 bg-white bg-opacity-25" style="width: 2.5rem; height: 2.5rem;">
                        <svg style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <span class="badge rounded-pill bg-white bg-opacity-10 text-white-50 small">Tổng</span>
                </div>
                <p class="fs-4 fw-bold mb-1">@((((decimal)ViewBag.TotalRevenue)).ToString("N0")) ₫</p>
                <p class="text-white-50 small mb-0">Doanh thu</p>
            </div>
        </div>
    </div>

    <!-- Today Revenue -->
    <div class="col-12 col-md-6 col-lg-4 col-xl-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center justify-content-center rounded-3 bg-warning bg-opacity-10" style="width: 2.5rem; height: 2.5rem;">
                        <svg class="text-warning" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <span class="badge rounded-pill bg-cream border small text-muted-custom">Hôm nay</span>
                </div>
                <p class="fs-4 fw-bold text-primary mb-1">@((((decimal)ViewBag.TodayRevenue)).ToString("N0")) ₫</p>
                <p class="text-muted-custom small mb-0">Doanh thu ngày</p>
            </div>
        </div>
    </div>

    <!-- Total Orders -->
    <div class="col-12 col-md-6 col-lg-4 col-xl-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center justify-content-center rounded-3 bg-info bg-opacity-10" style="width: 2.5rem; height: 2.5rem;">
                        <svg class="text-info" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    </div>
                    <span class="badge rounded-pill bg-cream border small text-muted-custom">Tất cả</span>
                </div>
                <p class="fs-4 fw-bold text-primary mb-1">@ViewBag.TotalOrders</p>
                <p class="text-muted-custom small mb-0">Đơn hàng</p>
            </div>
        </div>
    </div>

    <!-- Products -->
    <div class="col-12 col-md-6 col-lg-4 col-xl-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center justify-content-center rounded-3 bg-success bg-opacity-10" style="width: 2.5rem; height: 2.5rem;">
                        <svg class="text-success" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                    </div>
                    <span class="badge rounded-pill bg-cream border small text-muted-custom">Active</span>
                </div>
                <p class="fs-4 fw-bold text-primary mb-1">@ViewBag.ActiveProducts / @ViewBag.TotalProducts</p>
                <p class="text-muted-custom small mb-0">Sản phẩm</p>
            </div>
        </div>
    </div>
</div>

<!-- Pending alert -->
@if ((int)ViewBag.PendingOrders > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-3 rounded-3 mb-4" role="alert">
        <svg class="flex-shrink-0" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        <p class="mb-0 small">Có <strong>@ViewBag.PendingOrders đơn hàng</strong> đang chờ xử lý.</p>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-status="Pending" class="ms-auto text-decoration-none fw-semibold small">Xem ngay →</a>
    </div>
}

<!-- Recent Orders (View Component) -->
@await Component.InvokeAsync("RecentOrders", new { count = 5 })

<!-- ===== Sales Chart + Best Sellers ===== -->
<div class="row g-4 mt-4">

    <!-- Sales Chart (View Component) -->
    <div class="col-12 col-xl-8">
        @await Component.InvokeAsync("RevenueChart")
    </div>

    <!-- Best Sellers (View Component) -->
    <div class="col-12 col-xl-4">
        @await Component.InvokeAsync("TopProducts", new { count = 5 })
    </div>
</div>

<!-- ===== AI Business Insights ===== -->
<div class="card shadow-sm mt-4">

<!-- ===== ML Sales Forecast ===== -->
<div class="card shadow-sm mt-4">
    <div class="card-body p-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center gap-2">
                <div class="d-flex align-items-center justify-content-center rounded-3 bg-success bg-opacity-10" style="width: 2.5rem; height: 2.5rem;">
                    <svg class="text-success" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
                <div>
                    <h5 class="fw-bold mb-0">ML Dự đoán doanh thu</h5>
                    <small class="text-muted-custom">Dùng ML.NET (SSA Time Series) để dự đoán</small>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <select id="forecastDays" class="form-select form-select-sm rounded-pill" style="width: auto;">
                    <option value="7" selected>7 ngày</option>
                    <option value="14">14 ngày</option>
                    <option value="30">30 ngày</option>
                </select>
                <button onclick="loadForecast()" id="forecastBtn" class="btn btn-success btn-sm rounded-pill px-3">
                    <svg class="me-1" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Dự đoán
                </button>
            </div>
        </div>
        <div id="forecastLoading" class="d-none text-center py-4">
            <div class="spinner-border text-success" role="status"></div>
            <p class="text-muted-custom mt-2 mb-0 small">ML đang phân tích và dự đoán...</p>
        </div>
        <div id="forecastError" class="d-none alert alert-warning small mb-0"></div>
        <div id="forecastChart" class="d-none">
            <canvas id="mlForecastCanvas" height="280"></canvas>
        </div>
        <div id="forecastEmpty" class="text-center text-muted-custom py-3">
            <p class="mb-0 small">Nhấn <strong>Dự đoán</strong> để ML.NET dự đoán doanh thu tương lai dựa trên dữ liệu lịch sử</p>
        </div>
    </div>
</div>

<!-- ===== AI Business Insights (existing) ===== -->
<div class="card shadow-sm mt-4">
    <div class="card-body p-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center gap-2">
                <div class="d-flex align-items-center justify-content-center rounded-3 bg-primary bg-opacity-10" style="width: 2.5rem; height: 2.5rem;">
                    <svg class="text-primary" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                </div>
                <div>
                    <h5 class="fw-bold mb-0">AI Phân tích kinh doanh</h5>
                    <small id="aiInsightsTime" class="text-muted-custom"></small>
                </div>
            </div>
            <button onclick="loadAiInsights()" id="aiInsightsBtn" class="btn btn-primary btn-sm rounded-pill px-3">
                <svg class="me-1" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                Phân tích
            </button>
        </div>
        <div id="aiInsightsLoading" class="d-none text-center py-4">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted-custom mt-2 mb-0 small">AI đang phân tích dữ liệu kinh doanh...</p>
        </div>
        <div id="aiInsightsContent" class="d-none">
            <div id="aiInsightsText" class="p-3 bg-cream rounded-3" style="white-space: pre-wrap; line-height: 1.7;"></div>
        </div>
        <div id="aiInsightsEmpty" class="text-center text-muted-custom py-3">
            <p class="mb-0 small">Nhấn <strong>Phân tích</strong> để AI đưa ra nhận xét về tình hình kinh doanh</p>
        </div>
    </div>
</div>

<!-- Chart.js Library -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>

@section Scripts {
<script>
    const chartData = window.__revenueChartData || { labels: [], values: [] };
    const ctx = document.getElementById('adminSalesChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: chartData.labels,
            datasets: [{
                label: 'Doanh thu (₫)',
                data: chartData.values,
                borderColor: getComputedStyle(document.documentElement).getPropertyValue('--bs-primary').trim(),
                backgroundColor: 'rgba(212,165,116,0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4,
                pointRadius: 5,
                pointBackgroundColor: getComputedStyle(document.documentElement).getPropertyValue('--bs-secondary').trim(),
                pointBorderColor: getComputedStyle(document.documentElement).getPropertyValue('--bs-primary').trim(),
                pointBorderWidth: 2,
                pointHoverRadius: 7,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'white',
                    borderColor: getComputedStyle(document.documentElement).getPropertyValue('--color-border').trim(),
                    borderWidth: 1,
                    titleColor: getComputedStyle(document.documentElement).getPropertyValue('--bs-primary').trim(),
                    bodyColor: getComputedStyle(document.documentElement).getPropertyValue('--bs-primary').trim(),
                    padding: 12,
                    displayColors: false,
                    callbacks: { label: ctx => ctx.parsed.y.toLocaleString() + ' ₫' }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: getComputedStyle(document.documentElement).getPropertyValue('--color-border').trim() },
                    ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--color-medium-brown').trim(), font: { size: 11 }, callback: v => v.toLocaleString() + ' ₫' }
                },
                x: {
                    grid: { display: false },
                    ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--color-medium-brown').trim(), font: { size: 11 } }
                }
            }
        }
    });

    // SignalR real-time order updates
    const orderConnection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/order')
        .withAutomaticReconnect()
        .build();

    orderConnection.on('OrderUpdated', (orderId, status, statusText) => {
        // Show a toast notification
        const toast = document.createElement('div');
        toast.className = 'position-fixed bottom-0 end-0 m-4 p-3 bg-primary text-white rounded-3 shadow-lg';
        toast.style.cssText = 'z-index:9999; animation: fadeIn .3s ease;';
        toast.innerHTML = `<strong>Đơn #${String(orderId).padStart(4, '0')}</strong> → ${statusText}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    });

    orderConnection.start().then(() => orderConnection.invoke('JoinAdminDashboard'));

    // ── ML Sales Forecast ──
    let forecastChartInstance = null;
    async function loadForecast() {
        const btn = document.getElementById('forecastBtn');
        const loading = document.getElementById('forecastLoading');
        const chartDiv = document.getElementById('forecastChart');
        const empty = document.getElementById('forecastEmpty');
        const errorDiv = document.getElementById('forecastError');
        const days = document.getElementById('forecastDays').value;

        btn.disabled = true;
        empty.classList.add('d-none');
        chartDiv.classList.add('d-none');
        errorDiv.classList.add('d-none');
        loading.classList.remove('d-none');

        try {
            const res = await fetch('/api/Ai/admin/forecast?days=' + days);
            const data = await res.json();
            loading.classList.add('d-none');

            if (data.error) {
                errorDiv.textContent = data.error;
                errorDiv.classList.remove('d-none');
                btn.disabled = false;
                return;
            }

            const histLabels = data.historical.map(h => h.date.substring(5));
            const histValues = data.historical.map(h => h.revenue);
            const fcLabels = data.forecast.map(f => f.date.substring(5));
            const fcValues = data.forecast.map(f => f.revenue);
            const fcLower = data.forecast.map(f => f.lowerBound);
            const fcUpper = data.forecast.map(f => f.upperBound);

            const allLabels = [...histLabels, ...fcLabels];
            const historicalLine = [...histValues, ...new Array(fcValues.length).fill(null)];
            const forecastLine = [...new Array(histValues.length).fill(null)];
            forecastLine[histValues.length - 1] = histValues[histValues.length - 1];
            fcValues.forEach(v => forecastLine.push(v));

            const lowerLine = [...new Array(histValues.length).fill(null)];
            lowerLine[histValues.length - 1] = histValues[histValues.length - 1];
            fcLower.forEach(v => lowerLine.push(v));

            const upperLine = [...new Array(histValues.length).fill(null)];
            upperLine[histValues.length - 1] = histValues[histValues.length - 1];
            fcUpper.forEach(v => upperLine.push(v));

            if (forecastChartInstance) forecastChartInstance.destroy();

            const ctx = document.getElementById('mlForecastCanvas').getContext('2d');
            forecastChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: allLabels,
                    datasets: [
                        {
                            label: 'Doanh thu thực tế',
                            data: historicalLine,
                            borderColor: '#6366F1',
                            backgroundColor: 'rgba(99,102,241,0.08)',
                            borderWidth: 2.5,
                            fill: false,
                            tension: 0.3,
                            pointRadius: 2,
                            pointHoverRadius: 5,
                        },
                        {
                            label: 'Dự đoán ML',
                            data: forecastLine,
                            borderColor: '#10B981',
                            backgroundColor: 'rgba(16,185,129,0.08)',
                            borderWidth: 2.5,
                            borderDash: [6, 3],
                            fill: false,
                            tension: 0.3,
                            pointRadius: 3,
                            pointBackgroundColor: '#10B981',
                            pointHoverRadius: 6,
                        },
                        {
                            label: 'Khoảng tin cậy (trên)',
                            data: upperLine,
                            borderColor: 'rgba(16,185,129,0.2)',
                            backgroundColor: 'rgba(16,185,129,0.08)',
                            borderWidth: 1,
                            borderDash: [3, 3],
                            fill: '+1',
                            tension: 0.3,
                            pointRadius: 0,
                        },
                        {
                            label: 'Khoảng tin cậy (dưới)',
                            data: lowerLine,
                            borderColor: 'rgba(16,185,129,0.2)',
                            backgroundColor: 'rgba(16,185,129,0.08)',
                            borderWidth: 1,
                            borderDash: [3, 3],
                            fill: false,
                            tension: 0.3,
                            pointRadius: 0,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 16, font: { size: 11 } } },
                        tooltip: {
                            backgroundColor: 'white', borderColor: '#e5e7eb', borderWidth: 1,
                            titleColor: '#111', bodyColor: '#333', padding: 12, displayColors: true,
                            callbacks: { label: c => c.dataset.label + ': ' + (c.parsed.y !== null ? c.parsed.y.toLocaleString() + ' ₫' : '') }
                        }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#f3f4f6' }, ticks: { font: { size: 11 }, callback: v => v.toLocaleString() + ' ₫' } },
                        x: { grid: { display: false }, ticks: { font: { size: 10 }, maxRotation: 45 } }
                    }
                }
            });
            chartDiv.classList.remove('d-none');
        } catch (ex) {
            loading.classList.add('d-none');
            errorDiv.textContent = 'Không thể tải dự đoán. Vui lòng thử lại.';
            errorDiv.classList.remove('d-none');
        }
        btn.disabled = false;
    }

    // AI Insights
    async function loadAiInsights() {
        const btn = document.getElementById('aiInsightsBtn');
        const loading = document.getElementById('aiInsightsLoading');
        const content = document.getElementById('aiInsightsContent');
        const text = document.getElementById('aiInsightsText');
        const empty = document.getElementById('aiInsightsEmpty');
        const time = document.getElementById('aiInsightsTime');

        btn.disabled = true;
        empty.classList.add('d-none');
        content.classList.add('d-none');
        loading.classList.remove('d-none');

        try {
            const res = await fetch('/api/Ai/admin/insights');
            const data = await res.json();
            loading.classList.add('d-none');

            if (data.insights) {
                text.textContent = data.insights;
                time.textContent = 'Cập nhật: ' + data.updatedAt;
                content.classList.remove('d-none');
            } else {
                empty.classList.remove('d-none');
            }
        } catch {
            loading.classList.add('d-none');
            text.textContent = 'Không thể tải phân tích. Vui lòng thử lại.';
            content.classList.remove('d-none');
        }
        btn.disabled = false;
    }
</script>
}

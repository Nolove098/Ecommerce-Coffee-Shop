@model SaleStore.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - SaleStore</title>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Custom CSS -->
    <link href="~/css/custom.css" rel="stylesheet" />
    
    <style>
        .auth-bg {
            background:
                radial-gradient(circle at top left, rgba(var(--bs-secondary-rgb), 0.18), transparent 32%),
                radial-gradient(circle at bottom right, rgba(var(--bs-primary-rgb), 0.16), transparent 28%),
                linear-gradient(135deg, var(--color-dark-brown) 0%, #3D2010 48%, var(--bs-primary) 100%);
        }
        .glass { backdrop-filter: blur(20px); }
    </style>
</head>
<body class="min-vh-100 bg-cream text-dark">
    <div class="container-fluid min-vh-100 auth-bg">
        <div class="row g-0 min-vh-100">
            <div class="col-12 col-lg-7 position-relative overflow-hidden px-4 py-4 px-lg-5 py-lg-5 text-white d-flex flex-column">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="d-inline-flex align-items-center gap-3 text-decoration-none">
                        <div class="d-flex align-items-center justify-content-center bg-secondary rounded-2xl shadow-lg" style="width: 44px; height: 44px;">
                            <svg class="text-dark" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z" />
                                <line x1="6" y1="1" x2="6" y2="4" /><line x1="10" y1="1" x2="10" y2="4" /><line x1="14" y1="1" x2="14" y2="4" />
                            </svg>
                        </div>
                        <div>
                            <p class="fs-5 fw-bold serif mb-0 text-white">SaleStore</p>
                            <p class="small mb-0 text-white-50">Coffee crafted with intention</p>
                        </div>
                    </a>
                    <a asp-area="" asp-controller="Auth" asp-action="Register" class="d-none d-sm-inline-flex align-items-center gap-2 rounded-pill border border-white border-opacity-25 bg-white bg-opacity-10 px-4 py-2 small fw-medium text-white text-opacity-75 text-decoration-none">
                        Tạo tài khoản
                    </a>
                </div>
                <div class="flex-grow-1 d-flex align-items-center py-5 py-lg-0">
                    <div class="w-100" style="max-width: 48rem;">
                        <span class="d-inline-flex align-items-center gap-2 rounded-pill border border-secondary border-opacity-25 bg-secondary bg-opacity-10 px-4 py-2 small fw-semibold text-uppercase text-caramel" style="letter-spacing: 0.28em;">
                            Member Access
                        </span>
                        <h1 class="mt-4 display-4 fw-bold serif lh-sm">
                            Trở lại để tiếp tục
                            <span class="d-block text-caramel fst-italic">hành trình vị giác</span>
                        </h1>
                        <p class="mt-4 fs-6 lh-lg text-white text-opacity-75" style="max-width: 36rem;">
                            Đăng nhập để lưu dấu những món yêu thích, tăng tốc thanh toán và theo dõi lịch sử mua hàng trong hệ sinh thái SaleStore.
                        </p>

                        <div class="row g-3 mt-4">
                            <div class="col-12 col-sm-4">
                                <div class="glass rounded-2xl border border-white border-opacity-10 bg-white bg-opacity-10 p-4">
                                    <p class="display-6 fw-bold text-caramel serif mb-0">5'</p>
                                    <p class="mt-2 small text-white text-opacity-75 mb-0">Đặt món nhanh hơn với thông tin đã lưu</p>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="glass rounded-2xl border border-white border-opacity-10 bg-white bg-opacity-10 p-4">
                                    <p class="display-6 fw-bold text-caramel serif mb-0">24/7</p>
                                    <p class="mt-2 small text-white text-opacity-75 mb-0">Tài khoản sẵn sàng mọi lúc bạn cần</p>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="glass rounded-2xl border border-white border-opacity-10 bg-white bg-opacity-10 p-4">
                                    <p class="display-6 fw-bold text-caramel serif mb-0">100%</p>
                                    <p class="mt-2 small text-white text-opacity-75 mb-0">Mật khẩu được băm và bảo vệ an toàn</p>
                                </div>
                            </div>
                        </div>
                        <div class="mt-5 rounded-2xl border border-white border-opacity-10 bg-black bg-opacity-25 p-3 glass shadow-strong">
                            <div class="row g-3 align-items-center">
                                <div class="col-12 col-md-7">
                                    <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=900&auto=format&fit=crop" alt="Coffee counter" class="img-fluid rounded-xl" style="height: 20rem; width: 100%; object-fit: cover;" />
                                </div>
                                <div class="col-12 col-md-5">
                                    <div class="rounded-xl bg-cream p-4 text-dark">
                                        <p class="small fw-bold text-uppercase text-muted-custom mb-0" style="letter-spacing: 0.24em;">Signature Scene</p>
                                        <h2 class="mt-3 fs-3 fw-bold serif text-coffee">Bước vào quầy bar của SaleStore</h2>
                                        <p class="mt-3 small lh-lg text-muted mb-0">
                                            Không gian ấm, tông caramel và những ly cà phê được hoàn thiện như một nghi thức nhỏ mỗi ngày.
                                        </p>
                                        <div class="mt-4 d-flex flex-wrap gap-2">
                                            <span class="rounded-pill bg-light-brown px-3 py-2 small fw-semibold text-coffee">Arabica rang tươi</span>
                                            <span class="rounded-pill bg-light-brown px-3 py-2 small fw-semibold text-coffee">Checkout liền mạch</span>
                                            <span class="rounded-pill bg-light-brown px-3 py-2 small fw-semibold text-coffee">Member perks</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-5 d-flex align-items-center justify-content-center px-4 py-5 px-lg-5">
                <div class="w-100 rounded-2xl border shadow-strong bg-white p-4 p-sm-5" style="max-width: 36rem;">
                    <div class="mb-4 d-flex align-items-start justify-content-between gap-3">
                        <div>
                            <p class="small fw-semibold text-uppercase text-caramel mb-0" style="letter-spacing: 0.2em;">Đăng nhập</p>
                            <h2 class="mt-2 fs-3 fw-bold serif text-dark">Xin chào, mời bạn quay lại</h2>
                            <p class="mt-2 small lh-base text-muted-custom mb-0">Sử dụng email hoặc tên đăng nhập cùng mật khẩu để tiếp tục đặt món và quản lý tài khoản.</p>
                        </div>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="rounded-xl border px-3 py-2 small fw-semibold text-coffee text-decoration-none">Trang chủ</a>
                    </div>
                    <form asp-area="" asp-action="Login" asp-controller="Auth" method="post">
                        <input asp-for="ReturnUrl" type="hidden" />

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-xl border-danger mb-3"></div>
                        }

                        <div class="mb-3">
                            <label asp-for="LoginId" class="form-label"></label>
                            <input asp-for="LoginId" placeholder="you@example.com hoặc admin" class="form-control" />
                            <div asp-validation-for="LoginId" class="invalid-feedback d-block"></div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <label asp-for="Password" class="form-label mb-0"></label>
                                <span class="small text-muted-custom">Tối thiểu 6 ký tự</span>
                            </div>
                            <input asp-for="Password" placeholder="••••••••" class="form-control" />
                            <div asp-validation-for="Password" class="invalid-feedback d-block"></div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check rounded-xl bg-cream p-3">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label small text-muted">
                                    Giữ trạng thái đăng nhập trên thiết bị này
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fs-6 fw-bold shadow-lg">
                            Đăng nhập vào SaleStore
                        </button>
                    </form>
                    <div class="mt-4 rounded-xl border bg-cream p-4">
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <div>
                                <p class="small fw-semibold text-dark mb-1">Bạn chưa có tài khoản?</p>
                                <p class="small text-muted-custom mb-0">Tạo tài khoản mới để lưu thông tin và đăng nhập nhanh hơn.</p>
                            </div>
                            <a asp-area="" asp-controller="Auth" asp-action="Register" class="btn btn-secondary flex-shrink-0 px-4 py-2 small fw-bold text-decoration-none">
                                Đăng ký
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Bootstrap 5.3 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
</body>
</html>
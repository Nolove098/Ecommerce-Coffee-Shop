@page
@model SaleStore.Pages.MenuModel
@{
    ViewData["Title"] = "Thực đơn – SaleStore";
}

<!-- ===== HERO BANNER ===== -->
<section class="bg-gradient-primary text-white py-5 position-relative overflow-hidden">
    <div class="position-absolute top-0 end-0 opacity-10" style="width: 400px; height: 400px; background: radial-gradient(circle, var(--bs-secondary) 0%, transparent 70%);"></div>
    <div class="container-xxl px-4 py-5 position-relative">
        <div class="row align-items-center g-4">
            <div class="col-12 col-lg-8">
                <span class="badge bg-secondary text-dark rounded-pill px-3 py-2 mb-3">☕ Thực đơn đa dạng</span>
                <h1 class="display-3 fw-bold mb-3 serif">Khám phá thức uống</h1>
                <p class="fs-5 text-white-50 mb-0" style="max-width: 600px;">Từ cà phê nguyên chất đến thức uống sáng tạo — tất cả đều được pha chế bằng tình yêu và tay nghề của barista chuyên nghiệp.</p>
            </div>
            <div class="col-12 col-lg-4 text-center">
                <div class="d-inline-flex flex-column gap-3 bg-white bg-opacity-10 rounded-4 p-4 backdrop-blur">
                    <div class="d-flex align-items-center gap-3">
                        <div class="display-4">🔥</div>
                        <div class="text-start">
                            <p class="mb-0 small text-white-50">Bán chạy nhất</p>
                            <p class="mb-0 fw-bold">Caramel Macchiato</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="display-4">⭐</div>
                        <div class="text-start">
                            <p class="mb-0 small text-white-50">Đánh giá</p>
                            <p class="mb-0 fw-bold">4.9/5.0 từ 500+ khách</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== MENU ===== -->
<section id="menu" class="py-5 bg-white">
    <div class="container-xxl px-4">
        <!-- Mobile Sidebar Toggle Button -->
        <button id="sidebarToggle" class="btn btn-outline-primary d-md-none mb-3" type="button">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            Danh mục
        </button>
        
        <div class="row">
            <!-- Category Sidebar -->
            <aside class="col-12 col-md-3 mb-4 mb-md-0">
                <div class="category-sidebar">
                    <h3 class="fs-5 fw-bold text-dark mb-3">Danh mục</h3>
                    <ul class="list-unstyled">
                        <li class="@(Model.SelectedCategory == null ? "active" : "")">
                            <a href="/Menu" class="d-block text-decoration-none">
                                Tất cả (@Model.TotalProducts)
                            </a>
                        </li>
                        @foreach(var cat in Model.Categories)
                        {
                            <li class="@(Model.SelectedCategory == cat.Name ? "active" : "")">
                                <a href="/Menu?category=@cat.Name" class="d-block text-decoration-none">
                                    @cat.Name (@cat.ProductCount)
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </aside>

            <!-- Product Grid -->
            <div class="col-12 col-md-9">
                <!-- Product Count Display -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fs-5 fw-bold text-dark mb-0">
                        @if(Model.SelectedCategory != null)
                        {
                            <span>@Model.SelectedCategory</span>
                        }
                        else
                        {
                            <span>Tất cả sản phẩm</span>
                        }
                        <span class="text-muted fw-normal">(@Model.TotalProducts sản phẩm)</span>
                    </h2>
                </div>

                @if(Model.Products.Any())
                {
                    <div id="productGrid" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
                        @foreach(var p in Model.Products)
                        {
                            <div class="col product-card" data-cat="@p.Category">
                                <div class="card h-100 border rounded-4 overflow-hidden shadow-sm position-relative" style="cursor:pointer; transition:transform .2s,box-shadow .2s;" onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,.12)'" onmouseleave="this.style.transform='';this.style.boxShadow=''">
                                    <div class="position-relative bg-light-brown" style="height: 208px;">
                                        @if(!string.IsNullOrEmpty(p.ImageUrl))
                                        {
                                            <img src="@p.ImageUrl" alt="@p.Name" class="w-100 h-100 object-fit-cover"/>
                                        }
                                        else
                                        {
                                            <div class="w-100 h-100 d-flex align-items-center justify-content-center display-3">☕</div>
                                        }
                                        <span class="position-absolute top-0 end-0 m-3 badge bg-white text-primary rounded-pill small fw-bold">@p.Category</span>
                                        @if(p.Stock < 20)
                                        { 
                                            <span class="position-absolute top-0 start-0 m-3 badge bg-warning text-white rounded-pill small fw-bold">Sắp hết</span> 
                                        }
                                    </div>
                                    <div class="card-body">
                                        <h3 class="card-title fw-bold small mb-1 serif">
                                            <a href="/san-pham/@p.Id" class="text-decoration-none text-dark stretched-link">@p.Name</a>
                                        </h3>
                                        @if(!string.IsNullOrEmpty(p.Description))
                                        {
                                            <p class="card-text text-muted line-clamp-2 mb-3" style="font-size: 0.75rem;">@p.Description</p>
                                        }
                                        else
                                        { 
                                            <div class="mb-3"></div> 
                                        }
                                        <div class="d-flex align-items-center justify-content-between">
                                            <div>
                                                <span class="text-primary fw-bold fs-5">@p.Price.ToString("N0")</span>
                                                <span class="text-muted-custom small">₫</span>
                                            </div>
                                            <button onclick="event.stopPropagation();event.preventDefault();addToCart(@p.Id,'@p.Name.Replace("'","\\'")',@p.Price,'@(p.ImageUrl ?? "")','@p.Category')"
                                                    class="btn btn-primary btn-sm rounded-xl d-flex align-items-center gap-1 fw-semibold shadow-sm position-relative" style="z-index:2;">
                                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                                                Thêm
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Empty State Message -->
                    <div class="text-center py-5">
                        <div class="display-1 mb-3">☕</div>
                        <h3 class="fs-4 fw-bold text-dark mb-2">Không tìm thấy sản phẩm</h3>
                        <p class="text-muted mb-4">Không có sản phẩm nào trong danh mục này. Vui lòng thử danh mục khác.</p>
                        <a href="/Menu" class="btn btn-primary">Xem tất cả sản phẩm</a>
                    </div>
                }

                <!-- Pagination Controls -->
                @if(Model.TotalPages > 1)
                {
                    <nav class="pagination-controls" aria-label="Điều hướng trang">
                        <a href="/Menu?@(Model.Category != null ? $"category={Model.Category}&" : "")page=@(Model.CurrentPage - 1)" 
                           class="btn btn-outline-primary @(Model.CurrentPage == 1 ? "disabled" : "")"
                           aria-label="Trang trước"
                           @(Model.CurrentPage == 1 ? "aria-disabled=true tabindex=-1" : "")>
                            Trước
                        </a>
                        <span class="page-indicator" aria-current="page">
                            Trang @Model.CurrentPage / @Model.TotalPages
                        </span>
                        <a href="/Menu?@(Model.Category != null ? $"category={Model.Category}&" : "")page=@(Model.CurrentPage + 1)" 
                           class="btn btn-outline-primary @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")"
                           aria-label="Trang sau"
                           @(Model.CurrentPage == Model.TotalPages ? "aria-disabled=true tabindex=-1" : "")>
                            Sau
                        </a>
                    </nav>
                }
            </div>
        </div>
    </div>
</section>

<!-- Sidebar Overlay for Mobile -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- ===== FEATURES ===== -->
<section class="py-5 bg-cream">
    <div class="container-xxl px-4">
        <div class="text-center mb-4">
            <h3 class="fs-4 fw-bold text-dark serif">Tại sao chọn SaleStore?</h3>
        </div>
        <div class="row g-3">
            @{ var features=new[]{new{icon="🌱",title="100% Organic",desc="Hạt cà phê hữu cơ từ nông trại Đà Lạt"},new{icon="⚡",title="Pha chế nhanh",desc="Phục vụ trong 5 phút, không phải chờ đợi"},new{icon="💯",title="Đảm bảo chất lượng",desc="Hoàn tiền 100% nếu không hài lòng"}}; }
            @foreach(var f in features){
                <div class="col-12 col-md-4">
                    <div class="card border rounded-4 p-4 text-center h-100 shadow-sm">
                        <div class="display-4 mb-3">@f.icon</div>
                        <h4 class="fs-6 fw-bold text-dark mb-2">@f.title</h4>
                        <p class="text-muted small mb-0">@f.desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
<script>
    // Mobile sidebar toggle functionality
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebar = document.querySelector('.category-sidebar');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    
    // Toggle sidebar on button click
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', () => {
            sidebar.classList.toggle('show');
            sidebarOverlay.classList.toggle('show');
        });
    }
    
    // Close sidebar when overlay is clicked
    if (sidebarOverlay) {
        sidebarOverlay.addEventListener('click', () => {
            sidebar.classList.remove('show');
            sidebarOverlay.classList.remove('show');
        });
    }
    
    // Auto-close sidebar on category selection (mobile only)
    document.querySelectorAll('.category-sidebar a').forEach(link => {
        link.addEventListener('click', () => {
            if (window.innerWidth < 768) {
                sidebar.classList.remove('show');
                sidebarOverlay.classList.remove('show');
            }
        });
    });
    
    // Add to cart functionality (existing)
</script>
}

@page "/Pages/Contact"
@model SaleStore.Pages.ContactModel
@{
    Layout = "/Pages/Shared/_PagesLayout.cshtml";
}

<!-- Hero Section -->
<section class="bg-gradient-to-r from-[#6F4E37] to-[#2C1810] text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl font-bold mb-4">Liên Hệ Với Chúng Tôi</h1>
        <p class="text-xl text-gray-300">Chúng tôi rất muốn nghe từ bạn. Hãy gửi tin nhắn cho chúng tôi</p>
    </div>
</section>

<!-- Main Content -->
<section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Contact Information -->
            <div>
                <h2 class="text-3xl font-bold text-[#2C1810] mb-8">Thông tin liên hệ</h2>

                <!-- Address -->
                <div class="mb-8">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-[#D4A574] rounded-lg flex items-center justify-center text-white text-xl flex-shrink-0">
                            📍
                        </div>
                        <div>
                            <h4 class="text-lg font-semibold text-[#2C1810] mb-2">Địa chỉ</h4>
                            <p class="text-gray-600">123 Đường Cà phê, Quận 1, TP.HCM, Việt Nam</p>
                        </div>
                    </div>
                </div>

                <!-- Phone -->
                <div class="mb-8">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-[#D4A574] rounded-lg flex items-center justify-center text-white text-xl flex-shrink-0">
                            📞
                        </div>
                        <div>
                            <h4 class="text-lg font-semibold text-[#2C1810] mb-2">Điện thoại</h4>
                            <p class="text-gray-600">(028) 1234 5678</p>
                            <p class="text-gray-600">Thứ 2 - Chủ nhật: 7:00 - 22:00</p>
                        </div>
                    </div>
                </div>

                <!-- Email -->
                <div class="mb-8">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-[#D4A574] rounded-lg flex items-center justify-center text-white text-xl flex-shrink-0">
                            📧
                        </div>
                        <div>
                            <h4 class="text-lg font-semibold text-[#2C1810] mb-2">Email</h4>
                            <p class="text-gray-600"><a href="mailto:hello@coffeeshop.vn" class="hover:text-[#D4A574]">hello@coffeeshop.vn</a></p>
                        </div>
                    </div>
                </div>

                <!-- Social -->
                <div class="mb-8">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-[#D4A574] rounded-lg flex items-center justify-center text-white text-xl flex-shrink-0">
                            🌐
                        </div>
                        <div>
                            <h4 class="text-lg font-semibold text-[#2C1810] mb-2">Theo dõi chúng tôi</h4>
                            <div class="flex space-x-4">
                                <a href="#" class="text-[#D4A574] hover:text-[#6F4E37]">Facebook</a>
                                <a href="#" class="text-[#D4A574] hover:text-[#6F4E37]">Instagram</a>
                                <a href="#" class="text-[#D4A574] hover:text-[#6F4E37]">TikTok</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div>
                <h2 class="text-3xl font-bold text-[#2C1810] mb-8">Gửi tin nhắn cho chúng tôi</h2>

                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
                        <p><strong>✓ Thành công!</strong></p>
                        <p>@Model.SuccessMessage</p>
                    </div>
                }

                <form method="post" class="space-y-4">
                    <!-- Name -->
                    <div>
                        <label for="form-name" class="block text-sm font-medium text-gray-700 mb-1">Tên của bạn</label>
                        <input type="text" id="form-name" asp-for="Form.Name" required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#D4A574] focus:border-transparent"
                               placeholder="Nhập tên của bạn">
                        <span class="text-red-600 text-sm" asp-validation-for="Form.Name"></span>
                    </div>

                    <!-- Email -->
                    <div>
                        <label for="form-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                        <input type="email" id="form-email" asp-for="Form.Email" required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#D4A574] focus:border-transparent"
                               placeholder="example@email.com">
                        <span class="text-red-600 text-sm" asp-validation-for="Form.Email"></span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label for="form-phone" class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                        <input type="tel" id="form-phone" asp-for="Form.Phone"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#D4A574] focus:border-transparent"
                               placeholder="(028) 1234 5678">
                        <span class="text-red-600 text-sm" asp-validation-for="Form.Phone"></span>
                    </div>

                    <!-- Subject -->
                    <div>
                        <label for="form-subject" class="block text-sm font-medium text-gray-700 mb-1">Chủ đề</label>
                        <input type="text" id="form-subject" asp-for="Form.Subject" required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#D4A574] focus:border-transparent"
                               placeholder="Chủ đề của bạn">
                        <span class="text-red-600 text-sm" asp-validation-for="Form.Subject"></span>
                    </div>

                    <!-- Message -->
                    <div>
                        <label for="form-message" class="block text-sm font-medium text-gray-700 mb-1">Tin nhắn</label>
                        <textarea id="form-message" asp-for="Form.Message" required rows="5"
                                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#D4A574] focus:border-transparent"
                                  placeholder="Viết tin nhắn của bạn ở đây..."></textarea>
                        <span class="text-red-600 text-sm" asp-validation-for="Form.Message"></span>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-full bg-[#D4A574] text-white py-3 rounded-lg font-semibold hover:bg-[#C89968] transition">
                        Gửi tin nhắn
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Map Section (Optional) -->
<section class="bg-gray-200 h-96">
    <div class="w-full h-full flex items-center justify-center text-gray-600">
        <p>Bản đồ sẽ được nhúng tại đây (Google Maps, Mapbox, v.v.)</p>
    </div>
</section>

@model SaleStore.Models.Order
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Đặt hàng thành công – SaleStore</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    
    <!-- Custom CSS -->
    <link href="~/css/custom.css" rel="stylesheet" />
    
    <style>
        @@keyframes checkPop {
            0%   { transform: scale(0); opacity: 0; }
            60%  { transform: scale(1.2); }
            100% { transform: scale(1); opacity: 1; }
        }
        .check-pop { animation: checkPop 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.3s both; }
        @@keyframes fadeUp {
            from { opacity:0; transform: translateY(16px); }
            to   { opacity:1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.5s ease both; }
        .delay-1 { animation-delay: 0.5s; }
        .delay-2 { animation-delay: 0.7s; }
        .delay-3 { animation-delay: 0.9s; }
    </style>
</head>
<body class="bg-cream d-flex flex-column" style="min-height: 100vh;">

<!-- Header -->
<header class="bg-dark-brown">
    <div class="container" style="max-width: 48rem;">
        <div class="d-flex align-items-center gap-3 px-3 py-3">
            <a href="/" class="d-flex align-items-center gap-3 text-decoration-none">
                <div class="d-flex align-items-center justify-content-center rounded-xl bg-secondary" style="width: 2.25rem; height: 2.25rem;">
                    <svg class="text-dark-brown" style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                        <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                    </svg>
                </div>
                <span class="text-white fw-bold fs-5 serif">SaleStore</span>
            </a>
        </div>
    </div>
</header>

<main class="flex-fill container px-3 py-5 w-100" style="max-width: 48rem;">

    <!-- Success icon -->
    <div class="text-center mb-5">
        <div class="d-flex align-items-center justify-content-center mx-auto mb-4 rounded-circle check-pop bg-success-soft" style="width: 6rem; height: 6rem;">
            <svg class="text-success-dark" style="width: 3rem; height: 3rem;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
        </div>
        <h1 class="display-4 fw-bold serif fade-up delay-1 text-dark-brown">Đặt hàng thành công! 🎉</h1>
        <p class="text-muted mt-3 mx-auto fade-up delay-2" style="max-width: 28rem;">
            Cảm ơn bạn đã tin tưởng SaleStore. Đơn hàng của bạn đang được xử lý và sẽ sớm được phục vụ.
        </p>
    </div>

    <div class="card border shadow-sm overflow-hidden fade-up delay-2 rounded-2xl border-light-brown">
        <div class="card-header text-white px-4 py-4 bg-gradient-primary-card">
            <p class="text-uppercase small fw-semibold mb-1 text-white-50" style="letter-spacing: 0.1em;">Phương thức thanh toán: @Model.PaymentMethod</p>
            @if (Model.IsPaid)
            {
                <p class="display-6 fw-bold serif mb-0">Đã thanh toán thành công ✨</p>
            }
            else
            {
                <p class="display-6 fw-bold serif mb-0">Đơn hàng đã được ghi nhận</p>
            }
        </div>

        <div class="card-body p-5 text-center">
            @if (Model.IsPaid)
            {
                <p class="mb-3 mx-auto text-muted-custom" style="max-width: 36rem; line-height: 2;">
                    Cảm ơn bạn! Giao dịch của bạn đã hoàn tất. Chúng tôi đã nhận được thanh toán cho đơn hàng #@Model.Id qua @Model.PaymentMethod.
                </p>
            }
            else
            {
                <p class="mb-3 mx-auto text-muted-custom" style="max-width: 36rem; line-height: 2;">
                    Đơn hàng #@Model.Id của bạn đã được gửi đi thành công. Vui lòng chuẩn bị số tiền <strong>@Model.TotalAmount.ToString("N0") ₫</strong> để thanh toán khi nhận hàng.
                </p>
            }
            <p class="small mb-0 text-muted-custom">
                Bạn sẽ được chuyển về trang chủ trong giây lát.
            </p>
        </div>
    </div>

    <!-- Actions -->
    <div class="mt-4 fade-up delay-3">
        <a href="/" onclick="if(window.CartSync)CartSync.clearCart();"
           class="btn btn-primary w-100 py-3 rounded-2xl fw-bold d-flex align-items-center justify-content-center gap-2 shadow-lg">
            <svg style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 6h18M3 18h18"/></svg>
            Về trang chủ
        </a>
    </div>
</main>

<script>window.__isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");</script>
<script src="/js/cart-sync.js"></script>
<script>
    // Clear cart after successful order
    CartSync.clearCart();
    setTimeout(() => { window.location.href = '/'; }, 4000);
</script>

<!-- Bootstrap JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>

</body>
</html>

@model IEnumerable<SaleStore.Models.Product>
@inject SaleStore.Data.ApplicationDbContext _context
@{
    Layout = null;
    var category = ViewBag.Category as string ?? "Tất cả";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var sortBy = ViewBag.SortBy as string ?? "name";
    
    var categories = _context.Products
        .Where(p => p.IsActive)
        .Select(p => p.Category)
        .Distinct()
        .ToList();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@category - SaleStore</title>
    <meta name="description" content="Danh mục @category - SaleStore"/>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    
    <!-- Custom CSS -->
    <link href="~/css/custom.css" rel="stylesheet"/>
</head>
<body class="bg-cream">

<!-- ===== NAVBAR ===== -->
<nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top">
    <div class="container-xxl">
        <a href="/" class="navbar-brand d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl shadow-sm" style="width: 40px; height: 40px;">
                <svg class="text-dark" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <span class="text-primary fw-bold fs-5 serif">SaleStore</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a href="/" class="nav-link">Trang chủ</a></li>
                <li class="nav-item"><a href="/#menu" class="nav-link">Thực đơn</a></li>
                <li class="nav-item"><a href="/#about" class="nav-link">Về chúng tôi</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- ===== BREADCRUMB ===== -->
<section class="py-3 bg-white border-bottom">
    <div class="container-xxl">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-primary">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/#menu" class="text-decoration-none text-primary">Thực đơn</a></li>
                <li class="breadcrumb-item active" aria-current="page">@category</li>
            </ol>
        </nav>
    </div>
</section>

<!-- ===== CATEGORY HEADER ===== -->
<section class="py-5 bg-white">
    <div class="container-xxl">
        <div class="text-center mb-4">
            <h1 class="display-4 fw-bold text-dark serif">@category</h1>
            <p class="text-muted">Khám phá các sản phẩm trong danh mục này</p>
        </div>
    </div>
</section>

<!-- ===== FILTERS AND PRODUCTS ===== -->
<section class="py-5">
    <div class="container-xxl">
        <div class="row g-4">
            <!-- Sidebar Filters -->
            <div class="col-12 col-lg-3">
                <div class="card border rounded-4 p-4 shadow-sm mb-4">
                    <h3 class="fs-5 fw-bold text-dark mb-3 serif">Danh mục</h3>
                    <div class="list-group list-group-flush">
                        <a href="/Product/Category?category=Tất cả&sortBy=@sortBy" 
                           class="list-group-item list-group-item-action border-0 @(category == "Tất cả" ? "active" : "")">
                            Tất cả
                        </a>
                        @foreach(var cat in categories)
                        {
                            <a href="/Product/Category?category=@cat&sortBy=@sortBy" 
                               class="list-group-item list-group-item-action border-0 @(category == cat ? "active" : "")">
                                @cat
                            </a>
                        }
                    </div>
                </div>

                <div class="card border rounded-4 p-4 shadow-sm">
                    <h3 class="fs-5 fw-bold text-dark mb-3 serif">Lọc theo giá</h3>
                    <form method="get" action="/Product/Category">
                        <input type="hidden" name="category" value="@category"/>
                        <input type="hidden" name="sortBy" value="@sortBy"/>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Giá tối thiểu</label>
                            <input type="number" name="minPrice" class="form-control" placeholder="0 ₫" value="@ViewBag.MinPrice"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Giá tối đa</label>
                            <input type="number" name="maxPrice" class="form-control" placeholder="1,000,000 ₫" value="@ViewBag.MaxPrice"/>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-xl fw-semibold">Áp dụng</button>
                    </form>
                </div>
            </div>

            <!-- Products Grid -->
            <div class="col-12 col-lg-9">
                <!-- Sorting and View Options -->
                <div class="card border rounded-4 p-3 shadow-sm mb-4">
                    <div class="row g-3 align-items-center">
                        <div class="col-12 col-md-6">
                            <p class="mb-0 text-muted small">
                                Hiển thị <span class="fw-bold text-dark">@Model.Count()</span> sản phẩm
                            </p>
                        </div>
                        <div class="col-12 col-md-6">
                            <form method="get" action="/Product/Category" class="d-flex gap-2 align-items-center justify-content-md-end">
                                <input type="hidden" name="category" value="@category"/>
                                <input type="hidden" name="minPrice" value="@ViewBag.MinPrice"/>
                                <input type="hidden" name="maxPrice" value="@ViewBag.MaxPrice"/>
                                <label class="form-label small fw-semibold mb-0 text-nowrap">Sắp xếp:</label>
                                <select name="sortBy" class="form-select form-select-sm" onchange="this.form.submit()">
                                    <option value="name" selected="@(sortBy == "name")">Tên A-Z</option>
                                    <option value="name_desc" selected="@(sortBy == "name_desc")">Tên Z-A</option>
                                    <option value="price_asc" selected="@(sortBy == "price_asc")">Giá thấp đến cao</option>
                                    <option value="price_desc" selected="@(sortBy == "price_desc")">Giá cao đến thấp</option>
                                    <option value="newest" selected="@(sortBy == "newest")">Mới nhất</option>
                                </select>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Products Grid -->
                @if(Model.Any())
                {
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
                        @foreach(var product in Model)
                        {
                            <div class="col">
                                <div class="card h-100 border rounded-4 overflow-hidden shadow-sm">
                                    <div class="position-relative bg-light-brown" style="height: 240px;">
                                        @if(!string.IsNullOrEmpty(product.ImageUrl))
                                        {
                                            <img src="@product.ImageUrl" alt="@product.Name" class="img-fluid w-100 h-100 object-fit-cover"/>
                                        }
                                        else
                                        {
                                            <div class="w-100 h-100 d-flex align-items-center justify-content-center display-3">☕</div>
                                        }
                                        <span class="position-absolute top-0 end-0 m-3 badge bg-white text-primary rounded-pill small fw-bold">@product.Category</span>
                                        @if(product.Stock < 20)
                                        {
                                            <span class="position-absolute top-0 start-0 m-3 badge bg-warning text-white rounded-pill small fw-bold">Sắp hết</span>
                                        }
                                    </div>
                                    <div class="card-body d-flex flex-column">
                                        <h3 class="card-title fw-bold text-dark small mb-2 serif">@product.Name</h3>
                                        @if(!string.IsNullOrEmpty(product.Description))
                                        {
                                            <p class="card-text text-muted mb-3" style="font-size: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                                @product.Description
                                            </p>
                                        }
                                        <div class="mt-auto">
                                            <div class="d-flex align-items-center justify-content-between mb-3">
                                                <div>
                                                    <span class="text-primary fw-bold fs-5">@product.Price.ToString("N0")</span>
                                                    <span class="text-muted small">₫</span>
                                                </div>
                                                <div class="d-flex gap-1">
                                                    @for(int i = 0; i < 5; i++)
                                                    {
                                                        <span class="text-secondary" style="font-size: 0.75rem;">★</span>
                                                    }
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <a href="/Product/Detail/@product.Id" class="btn btn-outline-primary btn-sm rounded-xl flex-grow-1">
                                                    Xem chi tiết
                                                </a>
                                                <button onclick="addToCart(@product.Id, '@product.Name.Replace("'", "\\'")', @product.Price)" 
                                                        class="btn btn-primary btn-sm rounded-xl">
                                                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    @if(totalPages > 1)
                    {
                        <nav aria-label="Product pagination">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link rounded-xl me-2" href="/Product/Category?category=@category&sortBy=@sortBy&page=@(currentPage - 1)&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice" aria-label="Previous">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                </li>
                                @for(int i = 1; i <= totalPages; i++)
                                {
                                    <li class="page-item @(currentPage == i ? "active" : "")">
                                        <a class="page-link rounded-xl mx-1" href="/Product/Category?category=@category&sortBy=@sortBy&page=@i&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice">@i</a>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link rounded-xl ms-2" href="/Product/Category?category=@category&sortBy=@sortBy&page=@(currentPage + 1)&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice" aria-label="Next">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
                else
                {
                    <div class="card border rounded-4 p-5 shadow-sm text-center">
                        <div class="display-1 mb-3">☕</div>
                        <h3 class="fs-4 fw-bold text-dark mb-2 serif">Không tìm thấy sản phẩm</h3>
                        <p class="text-muted mb-4">Không có sản phẩm nào trong danh mục này. Vui lòng thử danh mục khác.</p>
                        <a href="/" class="btn btn-primary rounded-xl fw-semibold">Về trang chủ</a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ===== FOOTER ===== -->
<footer class="py-5 bg-dark text-white-50">
    <div class="container-xxl">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-4 pb-4 border-bottom border-white border-opacity-10">
            <a href="/" class="d-flex align-items-center gap-3 text-decoration-none">
                <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl" style="width: 36px; height: 36px;">
                    <span class="text-dark">☕</span>
                </div>
                <span class="text-white fw-bold fs-5 serif">SaleStore</span>
            </a>
            <div class="d-flex flex-wrap gap-4 small">
                <a href="/" class="text-white-50 text-decoration-none">Trang chủ</a>
                <a href="/#menu" class="text-white-50 text-decoration-none">Thực đơn</a>
                <a href="/#about" class="text-white-50 text-decoration-none">Về chúng tôi</a>
                <a href="/#contact" class="text-white-50 text-decoration-none">Liên hệ</a>
            </div>
        </div>
        <div class="text-center pt-4">
            <p class="mb-0">© 2026 SaleStore. Được làm với ☕ và tình yêu.</p>
        </div>
    </div>
</footer>

<!-- Bootstrap 5.3 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>

<!-- Custom JavaScript -->
<script src="~/js/bootstrap-init.js"></script>

<script>
    function addToCart(productId, productName, price) {
        alert(`Đã thêm "${productName}" vào giỏ hàng!`);
        // TODO: Implement actual cart functionality
    }
</script>

</body>
</html>

@{
    var bestSellers = new[] {
new { id = 1, name = "Caramel Macchiato", sales = 342, revenue = 1368, trend = "+15%", image =
"https://cdn.pixabay.com/photo/2024/09/26/13/54/ai-generated-9076473_640.jpg" },
new { id = 2, name = "Cappuccino", sales = 298, revenue = 1192, trend = "+12%", image =
"https://images.unsplash.com/photo-1572442388796-11668a67e53d?w=400" },
new { id = 3, name = "Iced Latte", sales = 276, revenue = 1104, trend = "+8%", image =
"https://images.unsplash.com/photo-1517487881594-2787fef5ebf7?w=400" },
new { id = 4, name = "Espresso", sales = 245, revenue = 735, trend = "+5%", image =
"https://images.unsplash.com/photo-1579992357154-faf4bde95b3d?w=400" },
new { id = 5, name = "Mocha", sales = 198, revenue = 891, trend = "+10%", image =
"https://images.unsplash.com/photo-1607681034540-2c46cc71896d?w=400" },
};
}

<div class="bg-white p-6 rounded-3xl border border-[#E8DFD8] shadow-sm h-full">
    <div class="flex items-center gap-2 mb-6">
        <!-- Award Icon -->
        <svg class="w-5 h-5 text-[#D4A574]" fill="currentColor" viewBox="0 0 24 24">
            <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z" />
        </svg>
        <h3 class="text-lg font-bold text-[#6F4E37]">Best Sellers</h3>
    </div>

    <div class="space-y-4">
        @{
            int index = 0;
            foreach (var item in bestSellers)
            {
                index++;

                <div class="flex items-center gap-4 p-3 rounded-2xl hover:bg-[#FAF8F5] transition-colors">
                    <div class="flex-shrink-0 relative">
                        <img src="@item.image" alt="@item.name" class="w-14 h-14 rounded-xl object-cover" />
                        <div
                            class="absolute -top-1 -left-1 w-6 h-6 bg-gradient-to-br from-[#6F4E37] to-[#8B7355] rounded-full flex items-center justify-center text-white text-xs font-bold">
                            @index
                        </div>
                    </div>

                    <div class="flex-1 min-w-0">
                        <h4 class="font-bold text-[#6F4E37] truncate">@item.name</h4>
                        <div class="flex items-center gap-3 mt-1">
                            <span class="text-sm text-[#8B7355]">@item.sales sold</span>
                            <span class="text-xs text-green-600 font-medium flex items-center gap-1">
                                <!-- TrendingUp Icon -->
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M13 7h8m0 0v8m0-8L5.5 19.5" />
                                </svg>
                                @item.trend
                            </span>
                        </div>
                    </div>

                    <div class="text-right">
                        <p class="text-lg font-bold text-[#6F4E37]">$@item.revenue</p>
                        <p class="text-xs text-[#8B7355]">revenue</p>
                    </div>
                </div>
            }
            <div class="mt-6">

                <button
                    class="w-full mt-4 py-3 bg-[#FAF8F5] hover:bg-[#F5EBE0] text-[#6F4E37] font-medium rounded-xl transition-colors">
                    View Full Report
                </button>
            </div>
        }
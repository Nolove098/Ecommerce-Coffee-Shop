@model SaleStore.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - SaleStore</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .serif { font-family: 'Playfair Display', serif; }
        .auth-bg {
            background:
                radial-gradient(circle at top left, rgba(212,165,116,0.18), transparent 32%),
                radial-gradient(circle at bottom right, rgba(111,78,55,0.16), transparent 28%),
                linear-gradient(135deg, #1A0E08 0%, #3D2010 48%, #6F4E37 100%);
        }
        .glass { backdrop-filter: blur(20px); }
    </style>
</head>
<body class="min-h-screen bg-[#FAF8F5] text-[#1A0E08]">
    <div class="min-h-screen grid lg:grid-cols-[1.15fr_0.85fr] auth-bg">
        <section class="relative overflow-hidden px-6 py-8 lg:px-12 lg:py-10 text-white flex flex-col">
            <div class="flex items-center justify-between">
                <a asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-3">
                    <div class="w-11 h-11 rounded-2xl bg-[#D4A574] flex items-center justify-center shadow-lg">
                        <svg class="w-6 h-6 text-[#1A0E08]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z" />
                            <line x1="6" y1="1" x2="6" y2="4" /><line x1="10" y1="1" x2="10" y2="4" /><line x1="14" y1="1" x2="14" y2="4" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-lg font-bold serif tracking-wide">SaleStore</p>
                        <p class="text-xs text-white/50">Coffee crafted with intention</p>
                    </div>
                </a>
                <a asp-area="" asp-controller="Auth" asp-action="Register" class="hidden sm:inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white">
                    Tạo tài khoản
                </a>
            </div>

            <div class="flex-1 flex items-center py-10 lg:py-0">
                <div class="max-w-2xl">
                    <span class="inline-flex items-center gap-2 rounded-full border border-[#D4A574]/30 bg-[#D4A574]/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] text-[#F4D8B7]">
                        Member Access
                    </span>
                    <h1 class="mt-6 text-5xl leading-[1.05] font-bold serif lg:text-6xl">
                        Trở lại để tiếp tục
                        <span class="block text-[#D4A574] italic">hành trình vị giác</span>
                    </h1>
                    <p class="mt-6 max-w-xl text-base leading-8 text-white/68 lg:text-lg">
                        Đăng nhập để lưu dấu những món yêu thích, tăng tốc thanh toán và theo dõi lịch sử mua hàng trong hệ sinh thái SaleStore.
                    </p>

                    <div class="mt-10 grid gap-4 sm:grid-cols-3">
                        <div class="glass rounded-3xl border border-white/10 bg-white/8 p-5">
                            <p class="text-3xl font-bold text-[#F4D8B7] serif">5'</p>
                            <p class="mt-2 text-sm text-white/60">Đặt món nhanh hơn với thông tin đã lưu</p>
                        </div>
                        <div class="glass rounded-3xl border border-white/10 bg-white/8 p-5">
                            <p class="text-3xl font-bold text-[#F4D8B7] serif">24/7</p>
                            <p class="mt-2 text-sm text-white/60">Tài khoản sẵn sàng mọi lúc bạn cần</p>
                        </div>
                        <div class="glass rounded-3xl border border-white/10 bg-white/8 p-5">
                            <p class="text-3xl font-bold text-[#F4D8B7] serif">100%</p>
                            <p class="mt-2 text-sm text-white/60">Mật khẩu được băm và bảo vệ an toàn</p>
                        </div>
                    </div>

                    <div class="mt-10 rounded-[2rem] border border-white/10 bg-black/15 p-4 glass shadow-2xl">
                        <div class="grid gap-4 md:grid-cols-[1.15fr_0.85fr] md:items-center">
                            <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=900&auto=format&fit=crop" alt="Coffee counter" class="h-64 w-full rounded-[1.5rem] object-cover md:h-80" />
                            <div class="rounded-[1.5rem] bg-[#FAF8F5] p-6 text-[#1A0E08]">
                                <p class="text-xs font-bold uppercase tracking-[0.24em] text-[#8B7355]">Signature Scene</p>
                                <h2 class="mt-3 text-3xl font-bold serif text-[#6F4E37]">Bước vào quầy bar của SaleStore</h2>
                                <p class="mt-4 text-sm leading-7 text-[#6B5A4C]">
                                    Không gian ấm, tông caramel và những ly cà phê được hoàn thiện như một nghi thức nhỏ mỗi ngày.
                                </p>
                                <div class="mt-5 flex flex-wrap gap-2 text-xs font-semibold text-[#6F4E37]">
                                    <span class="rounded-full bg-[#F5EBE0] px-3 py-2">Arabica rang tươi</span>
                                    <span class="rounded-full bg-[#F5EBE0] px-3 py-2">Checkout liền mạch</span>
                                    <span class="rounded-full bg-[#F5EBE0] px-3 py-2">Member perks</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="flex items-center justify-center px-6 py-10 lg:px-10">
            <div class="w-full max-w-xl rounded-[2rem] border border-[#E8DFD8] bg-white p-7 shadow-[0_30px_80px_rgba(26,14,8,0.15)] sm:p-9">
                <div class="mb-8 flex items-start justify-between gap-4">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#D4A574]">Đăng nhập</p>
                        <h2 class="mt-2 text-3xl font-bold serif text-[#1A0E08]">Xin chào, mời bạn quay lại</h2>
                        <p class="mt-2 text-sm leading-6 text-[#8B7355]">Sử dụng email hoặc tên đăng nhập cùng mật khẩu để tiếp tục đặt món và quản lý tài khoản.</p>
                    </div>
                    <a asp-controller="Home" asp-action="Index" class="rounded-2xl border border-[#E8DFD8] px-4 py-2 text-sm font-semibold text-[#6F4E37] transition hover:border-[#D4A574] hover:bg-[#FAF8F5]">Trang chủ</a>
                </div>

                <form asp-area="" asp-action="Login" asp-controller="Auth" method="post" class="space-y-5">
                    <input asp-for="ReturnUrl" type="hidden" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
                    }

                    <div>
                        <label asp-for="LoginId" class="mb-2 block text-sm font-semibold text-[#6F4E37]"></label>
                        <input asp-for="LoginId" placeholder="you@example.com hoặc admin" class="w-full rounded-2xl border border-[#E8DFD8] bg-[#FDFAF8] px-4 py-3.5 text-sm outline-none transition focus:border-[#D4A574] focus:ring-4 focus:ring-[#D4A574]/20" />
                        <span asp-validation-for="LoginId" class="mt-1 block text-xs text-red-500"></span>
                    </div>

                    <div>
                        <div class="mb-2 flex items-center justify-between gap-3">
                            <label asp-for="Password" class="block text-sm font-semibold text-[#6F4E37]"></label>
                            <span class="text-xs text-[#8B7355]">Tối thiểu 6 ký tự</span>
                        </div>
                        <input asp-for="Password" placeholder="••••••••" class="w-full rounded-2xl border border-[#E8DFD8] bg-[#FDFAF8] px-4 py-3.5 text-sm outline-none transition focus:border-[#D4A574] focus:ring-4 focus:ring-[#D4A574]/20" />
                        <span asp-validation-for="Password" class="mt-1 block text-xs text-red-500"></span>
                    </div>

                    <label class="flex items-center gap-3 rounded-2xl bg-[#FAF8F5] px-4 py-3 text-sm text-[#6B5A4C]">
                        <input asp-for="RememberMe" class="h-4 w-4 rounded border-[#D4A574] text-[#6F4E37] focus:ring-[#D4A574]" />
                        <span>Giữ trạng thái đăng nhập trên thiết bị này</span>
                    </label>

                    <button type="submit" class="w-full rounded-2xl bg-[#6F4E37] px-5 py-4 text-base font-bold text-white shadow-xl transition hover:bg-[#5D3A1A]">
                        Đăng nhập vào SaleStore
                    </button>
                </form>

                <div class="mt-8 rounded-[1.75rem] border border-[#E8DFD8] bg-[#FAF8F5] p-5">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <p class="text-sm font-semibold text-[#1A0E08]">Bạn chưa có tài khoản?</p>
                            <p class="mt-1 text-sm text-[#8B7355]">Tạo tài khoản mới để lưu thông tin và đăng nhập nhanh hơn.</p>
                        </div>
                        <a asp-area="" asp-controller="Auth" asp-action="Register" class="inline-flex shrink-0 items-center rounded-2xl bg-[#D4A574] px-4 py-3 text-sm font-bold text-[#1A0E08] transition hover:bg-[#C4956A]">
                            Đăng ký
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </div>
</body>
</html>
@inject SaleStore.Data.ApplicationDbContext _context
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0 "/>
    <title>@(ViewData["Title"] ?? "SaleStore")</title>
    <meta name="description" content="SaleStore – Cà phê & Thức uống chọn lọc"/>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    
    <!-- Custom CSS -->
    <link href="~/css/custom.css" rel="stylesheet"/>
    
    <style>
        html { scroll-behavior: smooth; }
        @@keyframes fadeUp {
            from { opacity:0; transform:translateY(20px); }
            to   { opacity:1; transform:translateY(0); }
        }
        .fade-up { animation: fadeUp 0.6s ease both; }
        @@keyframes slideIn {
            from { transform: translateX(100%); }
            to   { transform: translateX(0); }
        }
        .slide-in { animation: slideIn 0.35s cubic-bezier(0.25,0.46,0.45,0.94) both; }
        @@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
        .floating { animation: float 3.5s ease-in-out infinite; }
        .nav-solid { background: rgba(26,14,8,0.96); backdrop-filter: blur(16px); }
        .line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    </style>
</head>
<body class="bg-cream overflow-x-hidden">

<!-- ===== NAVBAR ===== -->
<nav id="navbar" class="navbar navbar-expand-lg fixed-top py-2">
    <div class="container-xxl">
        <a href="/" class="navbar-brand d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl shadow-lg" style="width: 40px; height: 40px;">
                <svg class="text-dark" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <span class="text-white fw-bold fs-5 serif">SaleStore</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto me-3 mb-2 mb-lg-0">
                <li class="nav-item"><a href="#menu" class="nav-link text-white-50 small fw-medium">Thực đơn</a></li>
                <li class="nav-item"><a href="#about" class="nav-link text-white-50 small fw-medium">Về chúng tôi</a></li>
                <li class="nav-item"><a href="#popular" class="nav-link text-white-50 small fw-medium">Yêu thích</a></li>
                <li class="nav-item"><a href="#contact" class="nav-link text-white-50 small fw-medium">Liên hệ</a></li>
            </ul>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <button onclick="toggleCart()" class="btn btn-outline-light btn-sm position-relative d-flex align-items-center gap-2 rounded-xl">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 5H19m-5-5v5m-4-5v5"/>
                    </svg>
                    <span class="d-none d-sm-inline">Giỏ hàng</span>
                    <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary text-dark d-none">0</span>
                </button>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-none d-lg-flex align-items-center gap-2 rounded-3 border border-white border-opacity-25 bg-white bg-opacity-10 px-3 py-2 small text-white">
                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary fw-bold text-dark" style="width: 32px; height: 32px;">@User.Identity.Name?.Substring(0, 1).ToUpperInvariant()</span>
                        <div class="lh-sm">
                            <p class="mb-0 fw-semibold">@User.Identity.Name</p>
                            <p class="mb-0 text-white-50" style="font-size: 0.75rem;">Thành viên SaleStore</p>
                        </div>
                    </div>
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-none d-sm-block">
                        <button type="submit" class="btn btn-outline-light btn-sm rounded-xl">Đăng xuất</button>
                    </form>
                }
                else
                {
                    <a asp-area="" asp-controller="Auth" asp-action="Login" class="btn btn-outline-light btn-sm rounded-xl d-none d-sm-inline-flex">Đăng nhập</a>
                    <a asp-area="" asp-controller="Auth" asp-action="Register" class="btn btn-secondary btn-sm rounded-xl text-dark fw-bold d-none d-sm-inline-flex">Đăng ký</a>
                }
                @if (User.IsInRole(SaleStore.Models.AppRoles.Admin) || User.IsInRole(SaleStore.Models.AppRoles.Staff))
                {
                    <a asp-area="Staff" asp-controller="POS" asp-action="Index" class="btn btn-outline-light btn-sm rounded-xl d-none d-md-inline-flex">POS</a>
                }
                @if (User.IsInRole(SaleStore.Models.AppRoles.Admin))
                {
                    <a href="/Admin" class="d-none d-md-flex align-items-center gap-1 text-white-50 text-decoration-none" style="font-size: 0.75rem;">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        Admin
                    </a>
                }
            </div>
        </div>
    </div>
</nav>

<!-- ===== HERO ===== -->
<section class="bg-gradient-hero min-vh-100 d-flex align-items-center position-relative overflow-hidden">
    <div class="position-absolute top-0 end-0 rounded-circle bg-secondary-soft" style="width: 600px; height: 600px; pointer-events: none;"></div>
    <div class="position-absolute bottom-0 start-0 rounded-circle blur bg-primary-soft-15" style="width: 320px; height: 320px; margin-left: -80px; margin-bottom: -80px; pointer-events: none;"></div>
    <div class="container-xxl px-4 pt-5 pb-4" style="margin-top: 80px;">
        <div class="row g-5 align-items-center">
            <div class="col-12 col-lg-6">
                <div class="d-inline-flex align-items-center gap-2 border border-opacity-25 rounded-pill px-4 py-2 mb-4 fade-up bg-secondary-soft-20 border-secondary-soft">
                    <span class="rounded-circle bg-secondary" style="width: 6px; height: 6px;"></span>
                    <span class="text-secondary small fw-semibold">Hạt cà phê Arabica nguyên chất từ Đà Lạt</span>
                </div>
                <h1 class="display-3 fw-bold text-white lh-sm mb-4 fade-up serif">
                    Thức uống<br/>
                    <span class="text-secondary fst-italic">đậm vị,</span><br/>
                    <span class="text-white-50">đong đầy cảm xúc</span>
                </h1>
                <p class="text-white-50 fs-5 mb-5 fade-up" style="max-width: 500px;">
                    Từng ly cà phê được pha chế tỉ mỉ bởi barista lành nghề — sử dụng hạt rang tươi, phục vụ nhanh trong 5 phút.
                </p>
                <div class="d-flex flex-wrap gap-3 mb-5 fade-up">
                    <a href="#menu" class="btn btn-secondary btn-lg rounded-3 fw-bold d-inline-flex align-items-center gap-2 shadow-lg text-dark">
                        Xem thực đơn
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                    <button onclick="toggleCart()" class="btn btn-outline-light btn-lg rounded-3 fw-medium d-inline-flex align-items-center gap-2">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 5H19"/></svg>
                        Giỏ hàng của tôi
                    </button>
                </div>
                <div class="row g-4 mt-4 fade-up">
                    @{ var heroStats = new[]{ new{num="500+",label="Khách/ngày"},new{num="20+",label="Loại thức uống"},new{num="5★",label="Đánh giá TB"} }; }
                    @foreach(var s in heroStats){
                        <div class="col-4">
                            <div class="border-start border-white border-opacity-10 ps-4">
                                <p class="display-6 fw-bold text-secondary serif mb-1">@s.num</p>
                                <p class="text-white-50 small mb-0">@s.label</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-12 col-lg-6 d-none d-lg-flex justify-content-center align-items-center">
                <div class="position-relative floating">
                    <div class="rounded-circle border border-secondary border-opacity-25 d-flex align-items-center justify-content-center bg-gradient-floating" style="width: 380px; height: 380px; backdrop-filter: blur(8px);">
                        <img src="https://images.unsplash.com/photo-1572442388796-11668a67e53d?w=600" alt="Caramel Macchiato" class="rounded-circle object-fit-cover shadow-lg" style="width: 288px; height: 288px;"/>
                    </div>
                    <div class="position-absolute bottom-0 start-50 translate-middle-x bg-white rounded-3 px-4 py-3 shadow-lg d-flex align-items-center gap-3" style="margin-bottom: -20px; white-space: nowrap;">
                        <div class="d-flex align-items-center justify-content-center rounded-xl bg-gradient-secondary" style="width: 36px; height: 36px;">
                            <svg width="16" height="16" class="text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div>
                            <p class="text-muted mb-0" style="font-size: 10px; font-weight: 500;">Bán chạy nhất</p>
                            <p class="fw-bold text-dark mb-0 small">Caramel Macchiato · 65.000 ₫</p>
                        </div>
                    </div>
                    <div class="position-absolute top-0 end-0 bg-secondary rounded-3 px-3 py-2 text-white shadow-lg" style="margin-top: 24px; margin-right: -24px;">
                        <p class="mb-0" style="font-size: 0.75rem; font-weight: 500;">Đánh giá</p>
                        <p class="mb-0 fs-5 fw-bold">⭐ 4.9</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="position-absolute bottom-0 start-0 end-0">
        <svg viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none" style="width: 100%; height: 64px;">
            <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" class="fill-cream"/>
        </svg>
    </div>
</section>

<!-- ===== FEATURES ===== -->
<section class="py-5 bg-cream">
    <div class="container-xxl px-4">
        <div class="row g-4">
            @{ var features=new[]{new{icon="☕",title="Nguyên liệu tươi",desc="Hạt Arabica & Robusta chọn lọc từ Đà Lạt, rang tươi mỗi ngày."},new{icon="⚡",title="Phục vụ nhanh",desc="Thức uống được pha chế và phục vụ trong vòng 5 phút."},new{icon="🌿",title="Thân thiện môi trường",desc="Ly và ống hút làm từ vật liệu sinh học phân hủy."}}; }
            @foreach(var f in features){
                <div class="col-12 col-md-4">
                    <div class="card h-100 border rounded-4 p-4 shadow-sm">
                        <div class="display-4 mb-4">@f.icon</div>
                        <h3 class="fs-5 fw-bold text-dark mb-2 serif">@f.title</h3>
                        <p class="text-muted small mb-0">@f.desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== MENU ===== -->
<section id="menu" class="py-5 bg-white">
    <div class="container-xxl px-4">
        <div class="text-center mb-5">
            <span class="text-secondary small fw-bold text-uppercase" style="letter-spacing: 0.2em;">Thực đơn</span>
            <h2 class="display-4 fw-bold text-dark mt-2 serif">Khám phá thức uống</h2>
            <p class="text-muted mt-3 mx-auto" style="max-width: 500px;">Từ cà phê nguyên chất đến thức uống sáng tạo — tất cả đều được pha chế bằng tình yêu.</p>
        </div>
        <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
            @{ var cats=new[]{"Tất cả","Cà phê đặc biệt","Cà phê đá","Cà phê truyền thống","Trà & Khác"}; }
            @foreach(var c in cats){
                <button onclick="filterCat(this,'@c')" class="cat-btn btn btn-outline-primary rounded-pill small fw-semibold @(c=="Tất cả"?"active":"")">@c</button>
            }
        </div>
        @{ var menuProducts = _context.Products.Where(p=>p.IsActive).ToList(); }
        <div id="productGrid" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach(var p in menuProducts){
                <div class="col product-card" data-cat="@p.Category">
                    <div class="card h-100 border rounded-4 overflow-hidden shadow-sm">
                        <div class="position-relative bg-light-brown" style="height: 208px;">
                            @if(!string.IsNullOrEmpty(p.ImageUrl)){
                                <img src="@p.ImageUrl" alt="@p.Name" class="w-100 h-100 object-fit-cover"/>
                            }else{
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center display-3">☕</div>
                            }
                            <span class="position-absolute top-0 end-0 m-3 badge bg-white text-primary rounded-pill small fw-bold">@p.Category</span>
                            @if(p.Stock < 20){ <span class="position-absolute top-0 start-0 m-3 badge bg-warning text-white rounded-pill small fw-bold">Sắp hết</span> }
                        </div>
                        <div class="card-body">
                            <h3 class="card-title fw-bold text-dark small mb-1 serif">@p.Name</h3>
                            @if(!string.IsNullOrEmpty(p.Description)){
                                <p class="card-text text-muted line-clamp-2 mb-3" style="font-size: 0.75rem;">@p.Description</p>
                            }else{ <div class="mb-3"></div> }
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-primary fw-bold fs-5">@p.Price.ToString("N0")</span>
                                    <span class="text-muted-custom small">₫</span>
                                </div>
                                <button onclick="addToCart(@p.Id,'@p.Name.Replace("'","\\'")',@p.Price,'@(p.ImageUrl ?? "")','@p.Category')"
                                        class="btn btn-primary btn-sm rounded-xl d-flex align-items-center gap-1 fw-semibold shadow-sm">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                                    Thêm
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== ABOUT ===== -->
<section id="about" class="py-5 bg-cream">
    <div class="container-xxl px-4">
        <div class="row g-5 align-items-center">
            <div class="col-12 col-lg-6">
                <div class="position-relative">
                    <div class="rounded-4 overflow-hidden shadow-lg ratio ratio-4x3">
                        <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=800" alt="Barista pha cà phê" class="object-fit-cover"/>
                    </div>
                    <div class="position-absolute bottom-0 end-0 rounded-4 p-4 text-white shadow-lg bg-gradient-primary" style="margin-bottom: -24px; margin-right: -24px;">
                        <p class="display-4 fw-bold serif mb-1">5+</p>
                        <p class="text-white-50 small mb-0">Năm kinh nghiệm</p>
                    </div>
                    <div class="position-absolute top-0 start-0 bg-white rounded-3 px-4 py-3 shadow-lg border" style="margin-top: 24px; margin-left: -24px;">
                        <p class="display-6 fw-bold text-primary serif mb-1">500+</p>
                        <p class="text-muted mb-0" style="font-size: 0.75rem;">Khách hàng mỗi ngày</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <span class="text-secondary small fw-bold text-uppercase" style="letter-spacing: 0.2em;">Về chúng tôi</span>
                <h2 class="display-4 fw-bold text-dark mt-2 mb-4 serif">Đam mê pha chế<br/>từ những ngày đầu</h2>
                <p class="text-muted mb-3">SaleStore ra đời từ tình yêu với những ly cà phê đậm đà. Chúng tôi tin rằng mỗi ly cà phê là một câu chuyện — câu chuyện về nguồn gốc hạt, về bàn tay người pha, và về khoảnh khắc bạn thưởng thức.</p>
                <p class="text-muted mb-4">Hạt cà phê của chúng tôi được chọn lựa kỹ càng từ các nông trường Tây Nguyên, rang tươi mỗi tuần để giữ trọn hương vị đặc trưng.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#menu" class="btn btn-primary rounded-xl fw-semibold shadow-lg">Xem thực đơn</a>
                    <a href="#contact" class="btn btn-outline-primary rounded-xl fw-semibold">Liên hệ ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== POPULAR ===== -->
<section id="popular" class="py-5 bg-white">
    <div class="container-xxl px-4">
        <div class="text-center mb-5">
            <span class="text-secondary small fw-bold text-uppercase" style="letter-spacing: 0.2em;">Bán chạy nhất</span>
            <h2 class="display-4 fw-bold text-dark mt-2 serif">Được yêu thích tuần này</h2>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
            @{ var popularItems=new[]{new{name="Caramel Macchiato",price=65000,sold=342,img="https://images.unsplash.com/photo-1572442388796-11668a67e53d?w=400"},new{name="Cappuccino",price=55000,sold=298,img="https://images.unsplash.com/photo-1606791405792-1004f1718d0c?w=400"},new{name="Iced Latte",price=55000,sold=276,img="https://images.unsplash.com/photo-1517487881594-2787fef5ebf7?w=400"},new{name="Espresso",price=40000,sold=245,img="https://images.unsplash.com/photo-1579992357154-faf4bde95b3d?w=400"},new{name="Mocha",price=60000,sold=198,img="https://images.unsplash.com/photo-1607681034540-2c46cc71896d?w=400"}}; int rank=0; }
            @foreach(var item in popularItems){ rank++;
                <div class="col">
                    <div class="card bg-cream border rounded-4 p-3 text-center shadow-sm">
                        <div class="position-relative mb-3">
                            <img src="@item.img" alt="@item.name" class="w-100 rounded-3 object-fit-cover" style="height: 144px;"/>
                            <div class="position-absolute top-0 start-0 d-flex align-items-center justify-content-center rounded-circle text-white small fw-bold shadow bg-gradient-secondary-primary" style="width: 32px; height: 32px; margin-top: -8px; margin-left: -8px;">@rank</div>
                        </div>
                        <h3 class="fw-bold text-dark small mb-1 serif lh-sm">@item.name</h3>
                        <p class="text-secondary fw-bold small mb-1">@item.price.ToString("N0") ₫</p>
                        <p class="text-muted mb-0" style="font-size: 0.75rem;">@item.sold đơn tuần này</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== TESTIMONIALS ===== -->
<section class="py-5 position-relative overflow-hidden bg-gradient-testimonial">
    <div class="position-absolute top-0 start-0 end-0 bottom-0 opacity-10" style="background-image:radial-gradient(circle at 25% 50%, var(--bs-secondary) 0%,transparent 60%)"></div>
    <div class="container-xxl px-4 position-relative">
        <div class="text-center mb-5">
            <span class="text-secondary small fw-bold text-uppercase" style="letter-spacing: 0.2em;">Khách hàng nói gì</span>
            <h2 class="display-4 fw-bold text-white mt-2 serif">Phản hồi từ cộng đồng</h2>
        </div>
        <div class="row g-4">
            @{ var reviews=new[]{new{name="Nguyễn Văn An",role="Khách hàng thân thiết",text="Caramel Macchiato ở đây ngon nhất Hà Nội mình từng uống. Hương vị thật sự khác biệt, không quá ngọt mà vẫn đậm đà.",stars=5,avatar="NA"},new{name="Trần Thị Bích",role="Food Blogger",text="Không gian xinh xắn, đồ uống ngon, giá hợp lý. Mình đã ghé đây 3 lần và lần nào cũng hài lòng!",stars=5,avatar="TB"},new{name="Lê Hữu Phúc",role="Sinh viên",text="Cà phê Espresso ở đây đánh thức cảm giác tỉnh táo hoàn toàn. Rất phù hợp với các buổi ôn bài căng thẳng.",stars=5,avatar="LP"}}; }
            @foreach(var r in reviews){
                <div class="col-12 col-md-4">
                    <div class="card bg-white bg-opacity-10 border border-white border-opacity-10 rounded-4 p-4 h-100">
                        <div class="d-flex gap-1 mb-4">@for(int i=0;i<r.stars;i++){<span class="text-secondary fs-5">★</span>}</div>
                        <p class="text-white-50 small mb-4 fst-italic">"@r.text"</p>
                        <div class="d-flex align-items-center gap-3 mt-auto">
                            <div class="d-flex align-items-center justify-content-center rounded-circle text-dark fw-bold small shadow-lg bg-gradient-secondary" style="width: 40px; height: 40px;">@r.avatar</div>
                            <div>
                                <p class="text-white fw-semibold small mb-0">@r.name</p>
                                <p class="text-white-50 mb-0" style="font-size: 0.75rem;">@r.role</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== CONTACT ===== -->
<section id="contact" class="py-5 bg-cream">
    <div class="container px-4 text-center" style="max-width: 800px;">
        <span class="text-secondary small fw-bold text-uppercase" style="letter-spacing: 0.2em;">Tìm đến chúng tôi</span>
        <h2 class="display-4 fw-bold text-dark mt-2 mb-3 serif">Đến thăm SaleStore hôm nay</h2>
        <p class="text-muted mb-5 mx-auto" style="max-width: 600px;">Ghé thăm cửa hàng hoặc gọi đặt hàng — chúng tôi luôn sẵn sàng phục vụ bạn.</p>
        <div class="row g-4 mb-5">
            @{ var infos=new[]{new{icon="📍",label="Địa chỉ",val="123 Đường Cà Phê, Quận 1, TP.HCM"},new{icon="🕐",label="Giờ mở cửa",val="6:00 SA – 10:00 CH · Tất cả các ngày"},new{icon="📞",label="Điện thoại",val="0901 234 567"}}; }
            @foreach(var info in infos){
                <div class="col-12 col-md-4">
                    <div class="card border rounded-4 p-4 shadow-sm h-100">
                        <div class="display-4 mb-3">@info.icon</div>
                        <p class="text-muted-custom small fw-bold text-uppercase mb-2" style="font-size: 10px; letter-spacing: 0.15em;">@info.label</p>
                        <p class="text-dark fw-semibold small mb-0">@info.val</p>
                    </div>
                </div>
            }
        </div>
        <a href="#menu" class="btn btn-primary btn-lg rounded-3 fw-bold d-inline-flex align-items-center gap-3 shadow-lg">
            Đặt thức uống ngay
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
    </div>
</section>

<!-- ===== FOOTER ===== -->
<footer class="py-5 text-white-50 bg-dark-brown">
    <div class="container-xxl px-4">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-4 pb-4 border-bottom border-white border-opacity-10">
            <a href="/" class="d-flex align-items-center gap-3 text-decoration-none">
                <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl" style="width: 36px; height: 36px;"><span class="text-dark">☕</span></div>
                <span class="text-white fw-bold fs-5 serif">SaleStore</span>
            </a>
            <div class="d-flex flex-wrap gap-4 small">
                <a href="#menu" class="text-white-50 text-decoration-none">Thực đơn</a>
                <a href="#about" class="text-white-50 text-decoration-none">Về chúng tôi</a>
                <a href="#popular" class="text-white-50 text-decoration-none">Yêu thích</a>
                <a href="#contact" class="text-white-50 text-decoration-none">Liên hệ</a>
            </div>
        </div>
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 pt-4 small">
            <p class="mb-0">© 2026 SaleStore. Được làm với ☕ và tình yêu.</p>
            <div class="d-flex flex-wrap align-items-center justify-content-center gap-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-white-50">Xin chào, @User.Identity.Name</span>
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-link btn-sm text-white-50 text-decoration-none p-0">Đăng xuất</button>
                    </form>
                }
                else
                {
                    <a asp-area="" asp-controller="Auth" asp-action="Login" class="text-white-50 text-decoration-none">Đăng nhập</a>
                    <a asp-area="" asp-controller="Auth" asp-action="Register" class="text-white-50 text-decoration-none">Đăng ký</a>
                }
                @if (User.IsInRole(SaleStore.Models.AppRoles.Admin) || User.IsInRole(SaleStore.Models.AppRoles.Staff))
                {
                    <a asp-area="Staff" asp-controller="POS" asp-action="Index" class="text-white-50 text-decoration-none">POS</a>
                }
                @if (User.IsInRole(SaleStore.Models.AppRoles.Admin))
                {
                    <a href="/Admin" class="text-white-50 text-decoration-none d-flex align-items-center gap-1">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        Admin Panel
                    </a>
                }
            </div>
        </div>
    </div>
</footer>

<!-- ===== FLOATING CART BUTTON ===== -->
<button onclick="toggleCart()" id="floatingCartBtn" aria-label="Open shopping cart"
        class="btn btn-primary position-fixed bottom-0 end-0 rounded-3 shadow-lg d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; margin-bottom: 32px; margin-right: 32px; z-index: 1040;">
    <div class="position-relative">
        <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 5H19m-5-5v5m-4-5v5"/>
        </svg>
        <span id="floatCartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary text-dark d-none" style="font-size: 10px; margin-top: -12px; margin-left: -12px;">0</span>
    </div>
</button>

<!-- ===== CART DRAWER OVERLAY ===== -->
<!-- ===== CART DRAWER (Bootstrap Offcanvas) ===== -->
<div id="cartDrawer" class="offcanvas offcanvas-end" tabindex="-1" aria-labelledby="cartDrawerLabel" data-bs-backdrop="true" data-bs-scroll="false" style="width: 100%; max-width: 420px;">
    <!-- Header -->
    <div class="offcanvas-header bg-cream border-bottom">
        <div>
            <h2 id="cartDrawerLabel" class="offcanvas-title fs-5 fw-bold text-dark serif">Giỏ hàng</h2>
            <p id="cartItemCount" class="mb-0 text-muted-custom small">0 sản phẩm</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <!-- Cart Items -->
    <div id="cartItems" class="offcanvas-body overflow-auto p-4">
        <!-- Populated by JS -->
    </div>

    <!-- Empty state -->
    <div id="cartEmpty" class="offcanvas-body d-flex flex-column align-items-center justify-content-center text-center">
        <div class="display-3 mb-3">🛒</div>
        <p class="text-muted-custom fw-medium mb-2">Giỏ hàng đang trống</p>
        <p class="text-muted small">Hãy thêm những món đồ uống yêu thích!</p>
        <button onclick="closeCart(); setTimeout(()=>document.getElementById('menu').scrollIntoView({behavior:'smooth'}),300)" class="btn btn-primary rounded-xl small fw-semibold mt-3">Xem thực đơn</button>
    </div>

    <!-- Footer: Total + Checkout -->
    <div id="cartFooter" class="border-top bg-cream p-4 d-none">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <span class="small text-muted-custom">Tạm tính</span>
            <span id="cartTotal" class="fs-4 fw-bold text-primary">0 ₫</span>
        </div>
        <form id="checkoutForm" action="/Cart/Checkout" method="get">
            <input type="hidden" name="cartData" id="cartDataInput"/>
            <button type="button" onclick="goCheckout()" class="btn btn-primary w-100 rounded-3 fw-bold d-flex align-items-center justify-content-center gap-2 shadow-lg py-3">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Tiến hành thanh toán
            </button>
        </form>
        <button onclick="clearCart()" class="btn btn-link w-100 text-danger small fw-medium mt-2">Xóa giỏ hàng</button>
    </div>
</div>

<!-- ===== TOAST ===== -->
<div id="toast" class="position-fixed bottom-0 end-0 bg-dark text-white rounded-3 shadow-lg d-flex align-items-center gap-3 border border-secondary border-opacity-25" style="margin-bottom: 112px; margin-right: 32px; padding: 14px 20px; z-index: 1060; transform: translateX(128px); opacity: 0;">
    <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl flex-shrink-0" style="width: 28px; height: 28px;">
        <svg width="16" height="16" class="text-dark" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    </div>
    <span id="toastMsg" class="small fw-medium">Đã thêm vào giỏ!</span>
</div>

<!-- ===== SCRIPTS ===== -->
<script>
    // ── Navbar scroll ──
    window.addEventListener('scroll', () => {
        document.getElementById('navbar').classList.toggle('nav-solid', window.scrollY > 60);
    });

    // ── Category filter ──
    function filterCat(btn, cat) {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('#productGrid .product-card').forEach(card => {
            card.style.display = (cat === 'Tất cả' || card.dataset.cat === cat) ? '' : 'none';
        });
    }

    // ── Cart state ──
    const CART_KEY = 'ss_cart_v1';
    function getCart() {
        try { return JSON.parse(localStorage.getItem(CART_KEY)) || []; }
        catch { return []; }
    }
    function saveCart(cart) {
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
        renderCart();
        updateBadges();
    }

    // ── Add to cart ──
    function addToCart(id, name, price, img, category) {
        const cart = getCart();
        const existing = cart.find(i => i.productId === id);
        if (existing) {
            existing.quantity += 1;
        } else {
            cart.push({ productId: id, productName: name, price: price, imageUrl: img, category: category, quantity: 1 });
        }
        saveCart(cart);
        showToast(`Đã thêm "${name}" vào giỏ!`);
    }

    // ── Remove/update ──
    function removeFromCart(id) {
        saveCart(getCart().filter(i => i.productId !== id));
    }
    function updateQty(id, delta) {
        const cart = getCart();
        const item = cart.find(i => i.productId === id);
        if (!item) return;
        item.quantity = Math.max(1, item.quantity + delta);
        saveCart(cart);
    }
    function clearCart() {
        if (!confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?')) return;
        localStorage.removeItem(CART_KEY);
        renderCart(); updateBadges();
    }

    // ── Render cart drawer ──
    function renderCart() {
        const cart = getCart();
        const itemsEl  = document.getElementById('cartItems');
        const emptyEl  = document.getElementById('cartEmpty');
        const footerEl = document.getElementById('cartFooter');
        const countEl  = document.getElementById('cartItemCount');
        const totalEl  = document.getElementById('cartTotal');

        const total = cart.reduce((s, i) => s + i.price * i.quantity, 0);
        const count = cart.reduce((s, i) => s + i.quantity, 0);
        countEl.textContent = count + ' sản phẩm';
        totalEl.textContent = total.toLocaleString('vi-VN') + ' ₫';

        if (cart.length === 0) {
            itemsEl.classList.add('d-none');
            emptyEl.classList.remove('d-none');
            footerEl.classList.add('d-none');
        } else {
            itemsEl.classList.remove('d-none');
            emptyEl.classList.add('d-none');
            footerEl.classList.remove('d-none');
            itemsEl.innerHTML = cart.map(item => `
                <div class="card bg-cream border rounded-3 p-3 mb-3">
                    <div class="d-flex align-items-center gap-3">
                        ${item.imageUrl
                            ? `<img src="${item.imageUrl}" alt="${item.productName}" class="rounded-xl object-fit-cover flex-shrink-0" style="width: 64px; height: 64px;"/>`
                            : `<div class="rounded-xl bg-light-brown d-flex align-items-center justify-content-center flex-shrink-0 fs-2" style="width: 64px; height: 64px;">☕</div>`}
                        <div class="flex-fill min-w-0">
                            <p class="fw-semibold text-dark small text-truncate mb-1">${item.productName}</p>
                            <p class="text-secondary fw-bold small mb-2">${(item.price).toLocaleString('vi-VN')} ₫</p>
                            <div class="d-flex align-items-center gap-2">
                                <button onclick="updateQty(${item.productId},-1)" class="btn btn-sm btn-outline-primary rounded-2 lh-1 p-1" style="width: 28px; height: 28px;">−</button>
                                <span class="small fw-bold text-primary" style="width: 20px; text-align: center;">${item.quantity}</span>
                                <button onclick="updateQty(${item.productId},+1)" class="btn btn-sm btn-outline-primary rounded-2 lh-1 p-1" style="width: 28px; height: 28px;">+</button>
                            </div>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2 flex-shrink-0">
                            <button onclick="removeFromCart(${item.productId})" class="btn btn-link text-danger p-0">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            </button>
                            <p class="text-muted small fw-medium mb-0">${(item.price * item.quantity).toLocaleString('vi-VN')} ₫</p>
                        </div>
                    </div>
                </div>
            `).join('');
        }
    }

    // ── Update badges ──
    function updateBadges() {
        const count = getCart().reduce((s, i) => s + i.quantity, 0);
        const badge1 = document.getElementById('cartBadge');
        const badge2 = document.getElementById('floatCartBadge');
        [badge1, badge2].forEach(b => {
            if (count > 0) { b.textContent = count > 9 ? '9+' : count; b.classList.remove('d-none'); }
            else { b.classList.add('d-none'); }
        });
    }

    // ── Bootstrap Offcanvas instance ──
    let cartOffcanvasInstance = null;
    
    // ── Initialize Bootstrap Offcanvas ──
    function initCartOffcanvas() {
        const drawer = document.getElementById('cartDrawer');
        if (drawer && typeof bootstrap !== 'undefined') {
            cartOffcanvasInstance = new bootstrap.Offcanvas(drawer);
            
            // Add event listeners for offcanvas events
            drawer.addEventListener('shown.bs.offcanvas', function() {
                console.log('Cart offcanvas shown');
                renderCart();
            });
            
            drawer.addEventListener('hidden.bs.offcanvas', function() {
                console.log('Cart offcanvas hidden');
            });
        }
    }
    
    // ── Open/close using Bootstrap API ──
    function toggleCart() {
        if (cartOffcanvasInstance) {
            cartOffcanvasInstance.toggle();
        }
    }
    function openCart() {
        renderCart();
        if (cartOffcanvasInstance) {
            cartOffcanvasInstance.show();
        }
    }
    function closeCart() {
        if (cartOffcanvasInstance) {
            cartOffcanvasInstance.hide();
        }
    }

    // ── Checkout redirect ──
    function goCheckout() {
        const cart = getCart();
        if (cart.length === 0) { showToast('Giỏ hàng đang trống!'); return; }
        const params = new URLSearchParams({ cartData: JSON.stringify(cart) });
        window.location.href = '/Cart/Checkout?' + params.toString();
    }

    // ── Toast ──
    function showToast(msg) {
        document.getElementById('toastMsg').textContent = msg;
        const t = document.getElementById('toast');
        t.style.transform = 'translateX(0)';
        t.style.opacity = '1';
        setTimeout(() => {
            t.style.transform = 'translateX(128px)';
            t.style.opacity = '0';
        }, 3000);
    }

    // ── Init ──
    updateBadges();
    
    // Initialize Bootstrap Offcanvas when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCartOffcanvas);
    } else {
        initCartOffcanvas();
    }
</script>

<!-- Bootstrap 5.3 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>

</body>
</html>

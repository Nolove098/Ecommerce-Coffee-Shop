@page "/san-pham/{id:int}"
@model SaleStore.Pages.ProductDetailModel
@{
    Layout = null;
    ViewData["Title"] = Model.Product.Name + " – SaleStore";

    var highlights = Model.Product.Category switch {
        "Cà phê đặc biệt"     => new[] { new{icon="☕",label="Hạt",val="Arabica cao cấp"}, new{icon="🌡️",label="Nhiệt độ",val="92–96°C"}, new{icon="⏱️",label="Pha chế",val="5–7 phút"} },
        "Cà phê đá"           => new[] { new{icon="🧊",label="Phục vụ",val="Lạnh – đá viên"}, new{icon="☕",label="Hạt",val="Robusta & Arabica"}, new{icon="⏱️",label="Pha chế",val="3–5 phút"} },
        "Cà phê truyền thống" => new[] { new{icon="☕",label="Hạt",val="Robusta Tây Nguyên"}, new{icon="🌡️",label="Nhiệt độ",val="95–98°C"}, new{icon="⏱️",label="Pha chế",val="4–6 phút"} },
        _                     => new[] { new{icon="🫖",label="Loại",val="Thức uống"}, new{icon="🌿",label="Nguyên liệu",val="Tự nhiên"}, new{icon="⏱️",label="Pha chế",val="3–5 phút"} }
    };
    var enjoyTips = Model.Product.Category switch {
        "Cà phê đặc biệt"     => new[] {"Uống nóng để cảm nhận trọn vẹn hương thơm", "Không thêm đường để giữ nguyên vị espresso", "Phù hợp buổi sáng hoặc sau bữa ăn chính"},
        "Cà phê đá"           => new[] {"Uống ngay khi được phục vụ, tránh để đá tan nhiều", "Có thể thêm sữa hoặc syrup theo khẩu vị", "Lý tưởng cho những ngày nóng bức"},
        "Cà phê truyền thống" => new[] {"Pha phin chậm để chiết xuất hương vị đậm đà", "Thêm sữa đặc theo tỉ lệ 1:3 là chuẩn ngon", "Thưởng thức cùng bánh mì hoặc bánh ngọt Việt"},
        _                     => new[] {"Thưởng thức khi còn tươi để giữ nguyên hương vị", "Có thể tùy chỉnh độ ngọt theo khẩu vị cá nhân", "Uống lạnh hoặc nóng đều phù hợp"}
    };
    var ingredients = Model.Product.Category switch {
        "Cà phê đặc biệt"     => new[] {"Espresso double shot", "Sữa tươi nguyên kem", "Syrup caramel/vanilla", "Đá viên (nếu dùng nguội)"},
        "Cà phê đá"           => new[] {"Cà phê Robusta & Arabica blend", "Đá viên cao cấp", "Sữa tươi hoặc sữa oat", "Đường mía hoặc siro"},
        "Cà phê truyền thống" => new[] {"Cà phê Robusta Tây Nguyên rang mộc", "Sữa đặc có đường", "Nước sôi 95–98°C", "Phin nhôm/inox truyền thống"},
        _                     => new[] {"Nguyên liệu tươi chọn lọc", "Không chất bảo quản", "Đường mía tự nhiên", "Nước tinh khiết"}
    };
    var stockClass = Model.Product.Stock > 20 ? "badge-stock-ok" : (Model.Product.Stock > 0 ? "badge-stock-low" : "badge-stock-none");
    var stockText  = Model.Product.Stock > 20 ? "Còn hàng" : (Model.Product.Stock > 0 ? "Sắp hết (" + Model.Product.Stock + ")" : "Hết hàng");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="~/css/custom.css" rel="stylesheet"/>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .hero-product { background: linear-gradient(135deg, #1a0e08 0%, #2d1206 60%, #3D2010 100%); }
        .img-zoom { transition: transform .4s ease; }
        .img-zoom:hover { transform: scale(1.05); }
        .tip-item { border-left: 3px solid #0d6efd; padding-left: 1rem; }
        .related-card { transition: transform .2s, box-shadow .2s; cursor: pointer; }
        .related-card:hover { transform: translateY(-5px); box-shadow: 0 10px 28px rgba(0,0,0,.13) !important; }
        .badge-stock-ok   { background: #D1FAE5; color: #065F46; }
        .badge-stock-low  { background: #FEF3C7; color: #92400E; }
        .badge-stock-none { background: #FEE2E2; color: #991B1B; }
        .star { color: #F59E0B; }
        .ingredient-chip { background: #F5F0EB; border-radius: 999px; padding: .35rem .85rem; font-size: .82rem; font-weight: 500; color: #3D2010; display: inline-block; border: 1px solid #e0d5ca; }
        .highlight-chip { background: rgba(255,255,255,.1); border-radius: .75rem; padding: .85rem .6rem; text-align: center; }
        .review-avatar { width: 42px; height: 42px; flex-shrink: 0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100" style="background:#f7f2ed;">

<!-- Navbar -->
<nav class="hero-product py-3 px-0">
    <div class="container d-flex align-items-center justify-content-between">
        <a href="/" class="text-decoration-none d-flex align-items-center gap-2">
            <span style="font-size:1.5rem;">☕</span>
            <span class="text-white fw-bold fs-5" style="font-family:'Playfair Display',serif;">SaleStore</span>
        </a>
        <div class="d-flex align-items-center gap-2">
            <a href="/#menu" class="btn btn-outline-light btn-sm rounded-pill px-3">← Thực đơn</a>
            <a href="/" class="btn btn-light btn-sm rounded-pill px-3 text-dark fw-semibold">Trang chủ</a>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero-product text-white py-5 pb-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-white-50 text-decoration-none small">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/#menu" class="text-white-50 text-decoration-none small">Thực đơn</a></li>
                <li class="breadcrumb-item small" style="color:rgba(255,255,255,.5);">@Model.Product.Category</li>
                <li class="breadcrumb-item active text-white small" aria-current="page">@Model.Product.Name</li>
            </ol>
        </nav>
        <div class="row g-5 align-items-center">
            <!-- Product Image -->
            <div class="col-lg-5">
                <div class="position-relative rounded-4 overflow-hidden shadow-lg" style="aspect-ratio:1; max-width:440px; margin:auto;">
                    <span class="position-absolute top-0 start-0 m-3 px-3 py-1 rounded-pill small fw-semibold @stockClass" style="z-index:2;">@stockText</span>
                    <span class="position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill small fw-bold bg-warning text-dark" style="z-index:2;">⭐ 4.8</span>
                    @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                    {
                        <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" class="w-100 h-100 object-fit-cover img-zoom"/>
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50" style="font-size:5rem;">☕</div>
                    }
                </div>
            </div>
            <!-- Product Info -->
            <div class="col-lg-7">
                <span class="badge rounded-pill mb-3 px-3 py-2 small" style="background:rgba(255,255,255,.15); color:#fff;">@Model.Product.Category</span>
                <h1 class="display-5 fw-bold text-white mb-3" style="font-family:'Playfair Display',serif; line-height:1.15;">@Model.Product.Name</h1>
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="star fs-5">★★★★★</span>
                    <span class="small" style="color:rgba(255,255,255,.6);">4.8 / 5.0 · 128 đánh giá</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Product.Description))
                {
                    <p class="mb-4 lh-lg" style="color:rgba(255,255,255,.75);">@Model.Product.Description</p>
                }
                <!-- Highlight chips -->
                <div class="row g-2 mb-4">
                    @foreach (var h in highlights)
                    {
                        <div class="col-4">
                            <div class="highlight-chip">
                                <div class="fs-4 mb-1">@h.icon</div>
                                <div class="small mb-1" style="color:rgba(255,255,255,.6);">@h.label</div>
                                <div class="text-white fw-semibold small">@h.val</div>
                            </div>
                        </div>
                    }
                </div>
                <!-- Price + CTA -->
                <div class="d-flex align-items-center gap-4 flex-wrap">
                    <div>
                        <div class="small mb-1" style="color:rgba(255,255,255,.6);">Giá niêm yết</div>
                        <div class="fw-bold text-warning" style="font-size:2rem;">@Model.Product.Price.ToString("N0") ₫</div>
                    </div>
                    @if (Model.Product.Stock > 0)
                    {
                        <button id="addToCartBtn"
                                data-id="@Model.Product.Id"
                                data-name="@Model.Product.Name"
                                data-price="@Model.Product.Price"
                                data-img="@(Model.Product.ImageUrl ?? string.Empty)"
                                data-category="@Model.Product.Category"
                                onclick="handleAddCart(this)"
                                class="btn btn-warning btn-lg rounded-pill fw-bold px-4 shadow d-inline-flex align-items-center gap-2">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 5H19"/>
                            </svg>
                            Thêm vào giỏ
                        </button>
                    }
                    else
                    {
                        <button disabled class="btn btn-secondary btn-lg rounded-pill fw-bold px-4">Hết hàng</button>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Details Section -->
<section class="py-5 flex-fill" style="background:#f7f2ed;">
    <div class="container">
        <div class="row g-4">

            <!-- Nguyên liệu -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h3 class="h6 fw-bold text-uppercase tracking-wide mb-3" style="color:#7c5c3e; letter-spacing:.06em;">🧪 Nguyên liệu</h3>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var ing in ingredients)
                            {
                                <span class="ingredient-chip">@ing</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mẹo thưởng thức -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h3 class="h6 fw-bold text-uppercase mb-3" style="color:#7c5c3e; letter-spacing:.06em;">💡 Mẹo thưởng thức</h3>
                        <div class="d-flex flex-column gap-3">
                            @foreach (var tip in enjoyTips)
                            {
                                <div class="tip-item">
                                    <p class="mb-0 text-muted small lh-lg">@tip</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin thêm -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h3 class="h6 fw-bold text-uppercase mb-3" style="color:#7c5c3e; letter-spacing:.06em;">📋 Thông tin</h3>
                        <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                            <li class="d-flex justify-content-between small border-bottom pb-2">
                                <span class="text-muted">Danh mục</span>
                                <span class="fw-semibold text-dark">@Model.Product.Category</span>
                            </li>
                            <li class="d-flex justify-content-between small border-bottom pb-2">
                                <span class="text-muted">Tồn kho</span>
                                <span class="fw-semibold @(Model.Product.Stock > 20 ? "text-success" : Model.Product.Stock > 0 ? "text-warning" : "text-danger")">@stockText</span>
                            </li>
                            <li class="d-flex justify-content-between small border-bottom pb-2">
                                <span class="text-muted">Đánh giá</span>
                                <span class="fw-semibold text-dark star">★ 4.8 / 5</span>
                            </li>
                            <li class="d-flex justify-content-between small">
                                <span class="text-muted">Lượt bán</span>
                                <span class="fw-semibold text-dark">128+</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Reviews -->
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h3 class="h5 fw-bold mb-4" style="font-family:'Playfair Display',serif;">💬 Đánh giá từ khách hàng</h3>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="bg-light rounded-3 p-3 h-100">
                                    <div class="d-flex align-items-center gap-3 mb-2">
                                        <div class="review-avatar bg-primary text-white">A</div>
                                        <div>
                                            <div class="fw-semibold small">Nguyễn Văn An</div>
                                            <div class="star small">★★★★★</div>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-0">"Hương thơm tuyệt vời, vị cà phê đậm đà mà không quá đắng. Sẽ quay lại nhiều lần!"</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="bg-light rounded-3 p-3 h-100">
                                    <div class="d-flex align-items-center gap-3 mb-2">
                                        <div class="review-avatar bg-success text-white">B</div>
                                        <div>
                                            <div class="fw-semibold small">Trần Thị Bích</div>
                                            <div class="star small">★★★★★</div>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-0">"@Model.Product.Name là lựa chọn yêu thích của tôi. Không gian ấm cúng, đồ uống xuất sắc!"</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="bg-light rounded-3 p-3 h-100">
                                    <div class="d-flex align-items-center gap-3 mb-2">
                                        <div class="review-avatar bg-warning text-dark">P</div>
                                        <div>
                                            <div class="fw-semibold small">Lê Hữu Phúc</div>
                                            <div class="star small">★★★★☆</div>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-0">"Giá cả hợp lý, chất lượng ổn định. Nhân viên nhiệt tình và thân thiện."</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Related Products -->
@if (Model.RelatedProducts.Any())
{
    <section class="py-5 bg-white">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="h4 fw-bold mb-0" style="font-family:'Playfair Display',serif;">Sản phẩm cùng danh mục</h2>
                <a href="/#menu" class="text-decoration-none text-primary small fw-semibold">Xem tất cả →</a>
            </div>
            <div class="row row-cols-2 row-cols-md-4 g-3">
                @foreach (var p in Model.RelatedProducts)
                {
                    <div class="col">
                        <a href="/san-pham/@p.Id" class="text-decoration-none">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden related-card">
                                <div class="overflow-hidden bg-light" style="height:155px;">
                                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                                    {
                                        <img src="@p.ImageUrl" alt="@p.Name" class="w-100 h-100 object-fit-cover img-zoom"/>
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center fs-1">☕</div>
                                    }
                                </div>
                                <div class="card-body p-3">
                                    <span class="badge bg-light text-muted border small mb-1">@p.Category</span>
                                    <h3 class="card-title fw-bold text-dark small mb-1">@p.Name</h3>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span class="text-primary fw-bold small">@p.Price.ToString("N0") ₫</span>
                                        <span class="star" style="font-size:.72rem;">★★★★★</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Footer -->
<footer class="py-5 bg-dark text-white mt-auto">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-md-4">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span style="font-size:1.5rem;">☕</span>
                    <span class="fw-bold fs-5" style="font-family:'Playfair Display',serif;">SaleStore</span>
                </div>
                <p class="text-white-50 small mb-0">Cà phê chất lượng cao, phục vụ tận tâm.</p>
            </div>
            <div class="col-md-4 text-md-center">
                <div class="d-flex justify-content-md-center gap-3 flex-wrap">
                    <a href="/" class="text-white-50 text-decoration-none small">Trang chủ</a>
                    <a href="/#menu" class="text-white-50 text-decoration-none small">Thực đơn</a>
                    <a href="/#contact" class="text-white-50 text-decoration-none small">Liên hệ</a>
                </div>
            </div>
            <div class="col-md-4 text-md-end">
                <p class="text-white-50 small mb-0">© 2026 SaleStore. Made with ☕ & ❤️</p>
            </div>
        </div>
    </div>
</footer>

<!-- Toast Notification -->
<div id="toast-cart"
     class="position-fixed bottom-0 end-0 m-4 p-3 bg-success text-white rounded-3 shadow-lg d-flex align-items-center gap-2"
     style="z-index:9999; opacity:0; transform:translateY(20px); transition:all .3s ease; pointer-events:none; min-width:260px;">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
    </svg>
    <span id="toast-text">Đã thêm vào giỏ hàng!</span>
</div>

<script>
    const CART_KEY = 'ss_cart_v1';
    function getCart() {
        try { return JSON.parse(localStorage.getItem(CART_KEY)) || []; } catch { return []; }
    }
    function showToast(name) {
        const t = document.getElementById('toast-cart');
        document.getElementById('toast-text').textContent = '\u2713 Đã thêm "' + name + '" vào giỏ!';
        t.style.opacity = '1';
        t.style.transform = 'translateY(0)';
        setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(20px)'; }, 2500);
    }
    function handleAddCart(btn) {
        const id       = parseInt(btn.dataset.id);
        const name     = btn.dataset.name;
        const price    = parseFloat(btn.dataset.price);
        const img      = btn.dataset.img || ''; // Ensure it's at least an empty string
        const category = btn.dataset.category || '';
        const cart     = getCart();
        const existing = cart.find(i => i.productId === id);
        
        if (existing) { 
            existing.quantity += 1; 
        } else { 
            cart.push({ 
                productId: id, 
                productName: name, 
                price: price, 
                imageUrl: String(img), // Force string
                category: String(category), 
                quantity: 1 
            }); 
        }
        
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
        const orig = btn.innerHTML;
        btn.innerHTML = '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Đã thêm!';
        btn.disabled = true;
        setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 2000);
        showToast(name);
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
</body>
</html>

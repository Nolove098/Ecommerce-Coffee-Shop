@model SaleStore.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - SaleStore</title>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Custom CSS -->
    <link href="~/css/custom.css" rel="stylesheet" />
    
    <style>
        .register-bg {
            background: var(--gradient-register);
        }
    </style>
</head>
<body class="min-vh-100 register-bg text-dark">
    <div class="container-fluid min-vh-100" style="max-width: 1600px; margin: 0 auto;">
        <div class="row g-0 min-vh-100">
            <section class="col-12 col-lg-5 d-flex align-items-center px-4 py-5 px-lg-5">
                <div class="w-100 rounded-2xl border shadow-strong bg-white bg-opacity-85 p-4 p-sm-5" style="backdrop-filter: blur(20px);">
                    <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="d-inline-flex align-items-center gap-3 text-decoration-none">
                            <div class="d-flex align-items-center justify-content-center bg-primary rounded-2xl shadow-lg" style="width: 44px; height: 44px;">
                                <svg class="text-white" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z" />
                                    <line x1="6" y1="1" x2="6" y2="4" /><line x1="10" y1="1" x2="10" y2="4" /><line x1="14" y1="1" x2="14" y2="4" />
                                </svg>
                            </div>
                            <div>
                                <p class="fs-5 fw-bold serif mb-0 text-dark">SaleStore</p>
                                <p class="small mb-0 text-muted-custom">Create your coffee account</p>
                            </div>
                        </a>
                        <a asp-area="" asp-controller="Auth" asp-action="Login" class="rounded-2xl border px-3 py-2 small fw-semibold text-coffee text-decoration-none">Đăng nhập</a>
                    </div>

                    <div class="my-4">
                        <p class="small fw-semibold text-uppercase text-caramel mb-0" style="letter-spacing: 0.22em;">Đăng ký</p>
                        <h1 class="mt-2 display-6 fw-bold serif text-dark">Tạo tài khoản thành viên</h1>
                        <p class="mt-3 small lh-lg text-muted-custom" style="max-width: 40rem;">Đăng ký để lưu thông tin liên hệ, truy cập nhanh hơn vào thanh toán và bắt đầu hành trình mua sắm đồng nhất cùng SaleStore.</p>
                    </div>

                    <form asp-area="" asp-action="Register" asp-controller="Auth" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-xl border-danger mb-3"></div>
                        }

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName" placeholder="Nguyễn Văn A" class="form-control" />
                                <div asp-validation-for="FullName" class="invalid-feedback d-block"></div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" placeholder="you@example.com" class="form-control" />
                                <div asp-validation-for="Email" class="invalid-feedback d-block"></div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="Phone" class="form-label"></label>
                                <input asp-for="Phone" placeholder="0901234567 hoặc +84 901 234 567" class="form-control" />
                                <div asp-validation-for="Phone" class="invalid-feedback d-block"></div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="Password" class="form-label"></label>
                                <input asp-for="Password" placeholder="Ví dụ: Aa@12345" class="form-control" />
                                <div asp-validation-for="Password" class="invalid-feedback d-block"></div>
                                <div class="form-text">Mật khẩu cần tối thiểu 8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt.</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="ConfirmPassword" class="form-label"></label>
                                <input asp-for="ConfirmPassword" placeholder="Nhập lại mật khẩu" class="form-control" />
                                <div asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></div>
                            </div>
                        </div>

                        <div class="mt-3 rounded-2xl border bg-cream p-4 small text-muted">
                            <p class="fw-semibold text-dark mb-3">Tài khoản mới của bạn sẽ có:</p>
                            <div class="row g-2">
                                <div class="col-12 col-sm-6">
                                    <div class="rounded-xl bg-white p-3">Lưu thông tin đăng nhập an toàn</div>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <div class="rounded-xl bg-white p-3">Truy cập nhanh vào trang thanh toán</div>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <div class="rounded-xl bg-white p-3">Theo dõi lịch sử đăng nhập cơ bản</div>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <div class="rounded-xl bg-white p-3">Quản lý thông tin thành viên thuận tiện</div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fs-6 fw-bold shadow-lg mt-3">
                            Tạo tài khoản ngay
                        </button>
                    </form>

                    <p class="mt-4 text-center small text-muted-custom">
                        Đã có tài khoản?
                        <a asp-area="" asp-controller="Auth" asp-action="Login" class="fw-bold text-coffee text-decoration-none">Đăng nhập tại đây</a>
                    </p>
                </div>
            </section>

            <section class="col-12 col-lg-7 position-relative overflow-hidden d-none d-lg-flex flex-column justify-content-center px-4 py-5">
                <div class="position-absolute rounded-circle bg-secondary-soft-25" style="left: 3rem; top: 3rem; width: 10rem; height: 10rem; filter: blur(60px);"></div>
                <div class="position-absolute rounded-circle bg-primary-soft-15" style="bottom: 2rem; right: 2rem; width: 13rem; height: 13rem; filter: blur(60px);"></div>

                <div class="position-relative ms-auto" style="max-width: 48rem;">
                    <div class="rounded-2xl bg-dark p-3 shadow-strong">
                        <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=1200&auto=format&fit=crop" alt="Warm coffee moment" class="img-fluid rounded-xl" style="height: 34rem; width: 100%; object-fit: cover;" />
                    </div>

                    <div class="position-absolute rounded-2xl border shadow-strong bg-white bg-opacity-90 p-4" style="left: -2.5rem; top: 2.5rem; max-width: 24rem; backdrop-filter: blur(20px);">
                        <p class="small fw-bold text-uppercase text-caramel mb-0" style="letter-spacing: 0.24em;">New Member Kit</p>
                        <h2 class="mt-3 fs-2 fw-bold serif text-dark">Một tài khoản, trọn trải nghiệm</h2>
                        <p class="mt-3 small lh-lg text-muted-custom mb-0">Thiết kế đăng ký theo cùng ngôn ngữ thị giác của SaleStore: nâu espresso, kem sữa và điểm nhấn caramel.</p>
                    </div>

                    <div class="position-absolute row g-3" style="bottom: -2rem; right: 1.5rem;">
                        <div class="col-12 col-sm-6">
                            <div class="rounded-2xl bg-primary p-4 text-white shadow-lg">
                                <p class="display-5 fw-bold serif mb-0 text-secondary-soft">2</p>
                                <p class="mt-2 small text-white text-opacity-75 mb-0">Bảng dữ liệu cho tài khoản và lịch sử đăng nhập</p>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="rounded-2xl border bg-cream p-4 shadow-lg">
                                <p class="display-5 fw-bold serif text-coffee mb-0">14d</p>
                                <p class="mt-2 small text-muted-custom mb-0">Ghi nhớ đăng nhập bằng cookie khi người dùng chọn</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
    
    <!-- Bootstrap 5.3 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
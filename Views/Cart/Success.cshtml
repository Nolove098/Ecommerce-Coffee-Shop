@model SaleStore.Models.Order
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Đặt hàng thành công – SaleStore</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .serif { font-family: 'Playfair Display', serif; }
        @@keyframes checkPop {
            0%   { transform: scale(0); opacity: 0; }
            60%  { transform: scale(1.2); }
            100% { transform: scale(1); opacity: 1; }
        }
        .check-pop { animation: checkPop 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.3s both; }
        @@keyframes fadeUp {
            from { opacity:0; transform: translateY(16px); }
            to   { opacity:1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.5s ease both; }
        .delay-1 { animation-delay: 0.5s; }
        .delay-2 { animation-delay: 0.7s; }
        .delay-3 { animation-delay: 0.9s; }
    </style>
</head>
<body class="bg-[#FAF8F5] min-h-screen flex flex-col">

<!-- Header -->
<header class="bg-[#1A0E08]">
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center gap-3">
        <a href="/" class="flex items-center gap-3">
            <div class="w-9 h-9 bg-[#D4A574] rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-[#1A0E08]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <span class="text-white font-bold text-lg serif">SaleStore</span>
        </a>
    </div>
</header>

<main class="flex-1 max-w-3xl mx-auto px-6 py-14 w-full">

    <!-- Success icon -->
    <div class="text-center mb-10">
        <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6 check-pop">
            <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
        </div>
        <h1 class="text-4xl font-bold text-[#1A0E08] serif fade-up delay-1">Đặt hàng thành công! 🎉</h1>
        <p class="text-gray-500 mt-3 max-w-md mx-auto fade-up delay-2">
            Cảm ơn bạn đã tin tưởng SaleStore. Đơn hàng của bạn đang được xử lý và sẽ sớm được phục vụ.
        </p>
    </div>

    <div class="bg-white rounded-3xl border border-[#E8DFD8] shadow-sm overflow-hidden fade-up delay-2">
        <div class="bg-gradient-to-br from-[#6F4E37] to-[#2C1810] px-7 py-6 text-white">
            <p class="text-white/60 text-xs font-medium uppercase tracking-widest mb-1">Trạng thái thanh toán</p>
            <p class="text-3xl font-bold serif">Đơn hàng đã được ghi nhận</p>
        </div>

        <div class="p-8 text-center">
            <p class="text-base leading-8 text-[#6B5A4C] max-w-xl mx-auto">
                Cảm ơn bạn đã đặt hàng tại SaleStore. Đơn hàng của bạn đã được gửi đi thành công và sẽ được đội ngũ cửa hàng xử lý trong thời gian sớm nhất.
            </p>
            <p class="mt-4 text-sm text-[#8B7355]">
                Bạn sẽ được chuyển về trang chủ sau vài giây.
            </p>
        </div>
    </div>

    <!-- Actions -->
    <div class="mt-8 fade-up delay-3">
        <a href="/" onclick="localStorage.removeItem('ss_cart_v1')"
           class="w-full bg-[#6F4E37] hover:bg-[#5D3A1A] text-white py-4 rounded-2xl font-bold text-center transition-colors shadow-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 6h18M3 18h18"/></svg>
            Về trang chủ
        </a>
    </div>
</main>

<script>
    // Clear cart after successful order
    localStorage.removeItem('ss_cart_v1');
    setTimeout(() => { window.location.href = '/'; }, 4000);
</script>

</body>
</html>

@page "/Pages/OrderSuccess"
@model SaleStore.Pages.OrderSuccessModel
@{
    Layout = "/Pages/Shared/_PagesLayout.cshtml";
    ViewData["Title"] = "Đặt hàng thành công";
}

<!-- Success Section -->
<section class="py-16 bg-[#FAF8F5]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-2xl shadow-lg p-8 text-center">
            <!-- Success Icon -->
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
            </div>

            <!-- Success Message -->
            <h1 class="text-3xl font-bold text-[#2C1810] mb-3">Đặt hàng thành công!</h1>
            <p class="text-gray-600 mb-8">Cảm ơn bạn đã đặt hàng. Chúng tôi sẽ liên hệ với bạn sớm nhất.</p>

            @if (Model.Order != null)
            {
                <!-- Order Info -->
                <div class="bg-[#FAF8F5] rounded-lg p-6 mb-6 text-left">
                    <h2 class="text-lg font-bold text-[#2C1810] mb-4">Thông tin đơn hàng</h2>
                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Mã đơn hàng:</span>
                            <span class="font-semibold">#@Model.Order.Id.ToString("D6")</span>
                        </div>
                        @if (Model.Customer != null)
                        {
                            <div class="flex justify-between">
                                <span class="text-gray-600">Người nhận:</span>
                                <span class="font-semibold">@Model.Customer.FullName</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Số điện thoại:</span>
                                <span class="font-semibold">@Model.Customer.Phone</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Order.ShippingAddress))
                        {
                            <div class="flex justify-between">
                                <span class="text-gray-600">Địa chỉ:</span>
                                <span class="font-semibold text-right max-w-xs">@Model.Order.ShippingAddress</span>
                            </div>
                        }
                        <div class="flex justify-between pt-3 border-t border-gray-300">
                            <span class="text-gray-600">Tổng tiền:</span>
                            <span class="text-xl font-bold text-[#6F4E37]">@Model.Order.TotalAmount.ToString("N0") ₫</span>
                        </div>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/" class="inline-block bg-[#6F4E37] hover:bg-[#5D3A1A] text-white px-8 py-3 rounded-lg font-semibold transition">
                    Về trang chủ
                </a>
                <a href="/Pages/Menu" class="inline-block border-2 border-[#6F4E37] text-[#6F4E37] hover:bg-[#6F4E37] hover:text-white px-8 py-3 rounded-lg font-semibold transition">
                    Tiếp tục mua hàng
                </a>
            </div>

            <!-- Additional Info -->
            <div class="mt-8 pt-6 border-t border-gray-200">
                @if (Model.Customer != null)
                {
                    <p class="text-sm text-gray-500">
                        📧 Cảm ơn bạn đã đặt hàng tại SaleStore
                    </p>
                }
                <p class="text-sm text-gray-500 mt-2">
                    📞 Hotline hỗ trợ: <span class="font-semibold text-[#6F4E37]">0901 234 567</span>
                </p>
            </div>
        </div>
    </div>
</section>

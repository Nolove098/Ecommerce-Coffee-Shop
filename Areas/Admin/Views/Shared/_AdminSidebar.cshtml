@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string NavClass(string ctrl) => currentController == ctrl ? "nav-active" : "text-white/70 hover:bg-white/10 hover:text-white";
}

<aside class="w-64 bg-gradient-to-b from-[#5D3A1A] to-[#6F4E37] text-white flex flex-col flex-shrink-0 shadow-xl">

    <!-- Logo -->
    <div class="px-6 py-5 border-b border-white/10">
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#D4A574] rounded-xl flex items-center justify-center shadow-md">
                <svg class="w-6 h-6 text-[#5D3A1A]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <div>
                <h1 class="text-base font-bold leading-tight">SaleStore</h1>
                <p class="text-xs text-white/60">Admin Panel</p>
            </div>
        </a>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-4 py-5 space-y-1">

        <p class="text-[10px] uppercase tracking-widest text-white/40 px-3 mb-2 font-semibold">Tổng quan</p>

        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
           class="flex items-center gap-3 px-4 py-2.5 rounded-xl @NavClass("Dashboard")">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                <polyline stroke-linecap="round" stroke-linejoin="round" points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span class="text-sm">Dashboard</span>
        </a>

        <p class="text-[10px] uppercase tracking-widest text-white/40 px-3 mt-5 mb-2 font-semibold">Quản lý</p>

        <a asp-area="Admin" asp-controller="Product" asp-action="Index"
           class="flex items-center gap-3 px-4 py-2.5 rounded-xl @NavClass("Product")">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
            <span class="text-sm">Sản phẩm</span>
        </a>

        <a asp-area="Admin" asp-controller="Order" asp-action="Index"
           class="flex items-center gap-3 px-4 py-2.5 rounded-xl @NavClass("Order")">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <span class="text-sm">Đơn hàng</span>
        </a>

        <div class="border-t border-white/10 my-4"></div>

        <a href="/" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-white/60 hover:bg-white/10 hover:text-white/90">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            <span class="text-sm">Về trang chủ</span>
        </a>
    </nav>

    <!-- Footer -->
    <div class="px-4 py-4 border-t border-white/10">
        <div class="flex items-center gap-3 bg-white/10 rounded-xl px-3 py-2">
            <div class="w-8 h-8 bg-[#D4A574] rounded-full flex items-center justify-center text-[#5D3A1A] text-xs font-bold">AD</div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium truncate">Admin</p>
                <p class="text-xs text-white/50">Quản trị viên</p>
            </div>
        </div>
    </div>
</aside>

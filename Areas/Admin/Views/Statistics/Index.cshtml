@using SaleStore.Areas.Admin.Controllers
@{
    ViewData["Title"] = "Thống kê";
    var period = (string)ViewBag.Period;
    var totalRevenue = (decimal)ViewBag.TotalRevenue;
    var totalOrders = (int)ViewBag.TotalOrders;
    var deliveredOrders = (int)ViewBag.DeliveredOrders;
    var totalCustomers = (int)ViewBag.TotalCustomers;
    var topProducts = (List<TopProductDto>)ViewBag.TopProducts;
}

<!-- Period filter -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <p class="small text-muted-custom mb-0">Thống kê doanh thu và sản phẩm bán chạy.</p>
    </div>
    <div class="btn-group" role="group">
        <a asp-action="Index" asp-route-period="week" class="btn btn-sm @(period == "week" ? "btn-primary" : "btn-outline-primary") rounded-start-pill">7 ngày</a>
        <a asp-action="Index" asp-route-period="month" class="btn btn-sm @(period == "month" ? "btn-primary" : "btn-outline-primary")">30 ngày</a>
        <a asp-action="Index" asp-route-period="year" class="btn btn-sm @(period == "year" ? "btn-primary" : "btn-outline-primary") rounded-end-pill">12 tháng</a>
    </div>
</div>

<!-- Summary cards -->
<div class="row g-4 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card border shadow-sm rounded-2xl">
            <div class="card-body p-4">
                <p class="text-uppercase small text-muted-custom fw-bold mb-2" style="letter-spacing: 0.22em;">Tổng doanh thu</p>
                <p class="fs-3 fw-bold text-coffee mb-0">@totalRevenue.ToString("N0") ₫</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border shadow-sm rounded-2xl">
            <div class="card-body p-4">
                <p class="text-uppercase small text-muted-custom fw-bold mb-2" style="letter-spacing: 0.22em;">Tổng đơn hàng</p>
                <p class="fs-3 fw-bold text-coffee mb-0">@totalOrders</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border shadow-sm rounded-2xl">
            <div class="card-body p-4">
                <p class="text-uppercase small text-muted-custom fw-bold mb-2" style="letter-spacing: 0.22em;">Đã giao</p>
                <p class="fs-3 fw-bold text-coffee mb-0">@deliveredOrders</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border shadow-sm rounded-2xl">
            <div class="card-body p-4">
                <p class="text-uppercase small text-muted-custom fw-bold mb-2" style="letter-spacing: 0.22em;">Khách hàng</p>
                <p class="fs-3 fw-bold text-coffee mb-0">@totalCustomers</p>
            </div>
        </div>
    </div>
</div>

<!-- Revenue chart -->
<div class="card border shadow-sm rounded-2xl mb-4">
    <div class="card-header bg-cream border-bottom px-4 py-3">
        <h2 class="h5 fw-bold text-coffee mb-0">Biểu đồ doanh thu</h2>
    </div>
    <div class="card-body p-4">
        <canvas id="revenueChart" height="100"></canvas>
    </div>
</div>

<!-- Orders count chart -->
<div class="card border shadow-sm rounded-2xl mb-4">
    <div class="card-header bg-cream border-bottom px-4 py-3">
        <h2 class="h5 fw-bold text-coffee mb-0">Số đơn hàng</h2>
    </div>
    <div class="card-body p-4">
        <canvas id="ordersChart" height="80"></canvas>
    </div>
</div>

<!-- Top products table -->
<div class="card border shadow-sm rounded-2xl overflow-hidden">
    <div class="card-header bg-cream border-bottom px-4 py-3">
        <h2 class="h5 fw-bold text-coffee mb-0">Top 10 sản phẩm bán chạy</h2>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light-brown text-muted-custom">
                <tr>
                    <th class="px-4 py-3 fw-semibold">#</th>
                    <th class="px-4 py-3 fw-semibold">Sản phẩm</th>
                    <th class="px-4 py-3 fw-semibold text-end">Số lượng bán</th>
                    <th class="px-4 py-3 fw-semibold text-end">Doanh thu</th>
                </tr>
            </thead>
            <tbody>
                @if (topProducts.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted-custom">Chưa có dữ liệu.</td>
                    </tr>
                }
                else
                {
                    var rank = 0;
                    @foreach (var p in topProducts)
                    {
                        rank++;
                        <tr>
                            <td class="px-4 py-3">
                                @if (rank <= 3)
                                {
                                    <span class="badge rounded-pill bg-secondary text-dark fw-bold">@rank</span>
                                }
                                else
                                {
                                    <span class="text-muted-custom">@rank</span>
                                }
                            </td>
                            <td class="px-4 py-3 fw-semibold text-coffee">@p.ProductName</td>
                            <td class="px-4 py-3 text-end">@p.TotalQuantity</td>
                            <td class="px-4 py-3 text-end fw-semibold">@p.TotalRevenue.ToString("N0") ₫</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const period = '@period';
        fetch(`/Admin/Statistics/ChartData?period=${period}`)
            .then(r => r.json())
            .then(data => {
                const primaryColor = '#6F4E37';
                const secondaryColor = '#B8884D';

                // Revenue chart
                new Chart(document.getElementById('revenueChart'), {
                    type: 'bar',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            label: 'Doanh thu (₫)',
                            data: data.revenues,
                            backgroundColor: primaryColor + '33',
                            borderColor: primaryColor,
                            borderWidth: 2,
                            borderRadius: 6,
                            hoverBackgroundColor: primaryColor + '66'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: ctx => ctx.parsed.y.toLocaleString('vi-VN') + ' ₫'
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: v => (v / 1000).toLocaleString('vi-VN') + 'k'
                                }
                            }
                        }
                    }
                });

                // Orders count chart
                new Chart(document.getElementById('ordersChart'), {
                    type: 'line',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            label: 'Số đơn hàng',
                            data: data.counts,
                            borderColor: secondaryColor,
                            backgroundColor: secondaryColor + '22',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 4,
                            pointBackgroundColor: secondaryColor
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { stepSize: 1 }
                            }
                        }
                    }
                });
            });
    </script>
}

@model IReadOnlyList<SaleStore.Models.Order>
@using SaleStore.Models

<div class="card rounded-3 shadow-sm overflow-hidden">
    <div class="card-header bg-white d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
        <h3 class="mb-0 fw-bold text-primary">Đơn hàng gần đây</h3>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="text-decoration-none text-primary fw-medium small">Xem tất cả →</a>
    </div>
    @if (!Model.Any())
    {
        <div class="card-body text-center py-5">
            <p class="text-muted mb-0">Chưa có đơn hàng nào.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 small">
                <thead class="bg-light-brown text-muted-custom">
                    <tr>
                        <th class="px-4 py-3 fw-semibold">#</th>
                        <th class="px-4 py-3 fw-semibold">Khách hàng</th>
                        <th class="px-4 py-3 fw-semibold">Tổng tiền</th>
                        <th class="px-4 py-3 fw-semibold">Trạng thái</th>
                        <th class="px-4 py-3 fw-semibold">Thời gian</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 text-primary fw-medium font-monospace">#@order.Id.ToString("D4")</td>
                            <td class="px-4 py-3 text-primary fw-medium">@(order.CustomerName ?? order.Customer?.FullName ?? "Khách lẻ")</td>
                            <td class="px-4 py-3 text-primary fw-semibold">@order.TotalAmount.ToString("N0") ₫</td>
                            <td class="px-4 py-3">
                                <span class="badge rounded-pill @order.Status.ToBadgeClass()">@order.Status.ToVietnamese()</span>
                            </td>
                            <td class="px-4 py-3 text-muted-custom">@order.CreatedAt.AddHours(7).ToString("HH:mm dd/MM")</td>
                            <td class="px-4 py-3 text-end">
                                <a asp-area="Admin" asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id"
                                   class="text-decoration-none text-primary fw-medium small">Chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@model SaleStore.Models.Order
@using SaleStore.Models
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Đơn hàng #@Model.Id.ToString("D4") – SaleStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="~/css/custom.css" rel="stylesheet"/>
</head>
<body class="bg-cream">

<!-- Header -->
<nav class="navbar bg-dark-brown">
    <div class="container" style="max-width: 800px;">
        <a href="/" class="navbar-brand d-flex align-items-center gap-2">
            <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl" style="width: 36px; height: 36px;">
                <svg class="text-dark" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <span class="text-white fw-bold fs-5 serif">SaleStore</span>
        </a>
        <a href="/Order/History" class="btn btn-outline-light btn-sm rounded-xl">← Đơn hàng của tôi</a>
    </div>
</nav>

<div class="container py-5" style="max-width: 800px;">

    <!-- Header -->
    <div class="card border rounded-4 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <h1 class="h4 fw-bold text-dark mb-0 font-monospace">Đơn #@Model.Id.ToString("D4")</h1>
                        <span class="badge @Model.Status.ToBadgeClass() fs-6">@Model.Status.ToVietnamese()</span>
                    </div>
                    <p class="text-muted small mb-0">Đặt lúc: @Model.CreatedAt.AddHours(7).ToString("HH:mm - dd/MM/yyyy")</p>
                </div>
                <div class="text-end">
                    <p class="fs-4 fw-bold text-primary mb-0">@Model.TotalAmount.ToString("N0") ₫</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Timeline -->
    <div class="card border rounded-4 shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold text-dark mb-4">Trạng thái đơn hàng</h5>
            @{
                var isCancelled = Model.Status == OrderStatus.Cancelled;
                var timelineSteps = new[] {
                    (Status: OrderStatus.Pending, Label: "Chờ xử lý", Desc: "Đơn hàng đã được tiếp nhận", Icon: "📋"),
                    (Status: OrderStatus.Ready, Label: "Sẵn sàng", Desc: "Đơn hàng đã sẵn sàng giao", Icon: "✅"),
                    (Status: OrderStatus.Delivered, Label: "Đã giao", Desc: "Đơn hàng đã giao thành công", Icon: "🎉")
                };
            }

            @if (isCancelled)
            {
                <div class="alert alert-danger d-flex align-items-center gap-3 rounded-3">
                    <span class="fs-4">❌</span>
                    <div>
                        <p class="fw-bold mb-0">Đơn hàng đã bị hủy</p>
                        <p class="small mb-0">Vui lòng liên hệ cửa hàng nếu bạn cần hỗ trợ.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-0">
                    @foreach (var (step, idx) in timelineSteps.Select((s, i) => (s, i)))
                    {
                        var isActive = (int)Model.Status >= (int)step.Status;
                        var isCurrent = Model.Status == step.Status;
                        <div class="d-flex gap-3">
                            <div class="d-flex flex-column align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center @(isActive ? "bg-primary shadow-sm" : "bg-light border") flex-shrink-0" style="width: 40px; height: 40px; font-size: 18px;">
                                    @step.Icon
                                </div>
                                @if (idx < timelineSteps.Length - 1)
                                {
                                    <div class="flex-grow-1 @(isActive && (int)Model.Status > (int)step.Status ? "bg-primary" : "bg-light")" style="width: 3px; min-height: 40px;"></div>
                                }
                            </div>
                            <div class="pb-4">
                                <p class="fw-bold mb-0 @(isActive ? "text-dark" : "text-muted")">@step.Label</p>
                                <p class="small mb-0 @(isActive ? "text-muted" : "text-muted opacity-50")">@step.Desc</p>
                                @if (isCurrent)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill mt-1 small">← Hiện tại</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Customer info -->
    @if (Model.Customer != null)
    {
        <div class="card border rounded-4 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold text-dark mb-3">Thông tin nhận hàng</h5>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <p class="small text-muted mb-1">Họ tên</p>
                        <p class="fw-semibold mb-0">@(Model.CustomerName ?? Model.Customer.FullName)</p>
                    </div>
                    <div class="col-sm-6">
                        <p class="small text-muted mb-1">Số điện thoại</p>
                        <p class="fw-semibold mb-0">@Model.Customer.Phone</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                    {
                        <div class="col-12">
                            <p class="small text-muted mb-1">Địa chỉ</p>
                            <p class="fw-semibold mb-0">@Model.ShippingAddress</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="col-12">
                            <div class="alert alert-warning mb-0 rounded-3 small" style="background-color: #FEF3C7; border-color: #FDE68A; color: #92400E;">
                                <strong>Ghi chú:</strong> @Model.Note
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Order items -->
    <div class="card border rounded-4 shadow-sm mb-4 overflow-hidden">
        <div class="card-header bg-white border-bottom p-4">
            <h5 class="fw-bold text-dark mb-0">Chi tiết sản phẩm</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-cream">
                    <tr>
                        <th class="text-start px-4 py-3 fw-semibold text-muted small">Sản phẩm</th>
                        <th class="text-center px-4 py-3 fw-semibold text-muted small">SL</th>
                        <th class="text-end px-4 py-3 fw-semibold text-muted small">Đơn giá</th>
                        <th class="text-end px-4 py-3 fw-semibold text-muted small">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td class="px-4 py-3 fw-medium">@item.ProductName</td>
                            <td class="px-4 py-3 text-center">@item.Quantity</td>
                            <td class="px-4 py-3 text-end text-muted">@item.UnitPrice.ToString("N0") ₫</td>
                            <td class="px-4 py-3 text-end fw-semibold">@item.LineTotal.ToString("N0") ₫</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-cream">
                    <tr>
                        <td colspan="3" class="px-4 py-3 text-end fw-bold">Tổng cộng</td>
                        <td class="px-4 py-3 text-end fw-bold fs-5 text-primary">@Model.TotalAmount.ToString("N0") ₫</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <!-- Actions -->
    <div class="d-flex flex-wrap gap-3">
        <a href="/Order/History" class="btn btn-outline-primary rounded-xl">
            ← Quay lại đơn hàng
        </a>
        <a href="/" class="btn btn-primary rounded-xl">
            Tiếp tục mua sắm
        </a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
</body>
</html>

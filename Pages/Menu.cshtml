@page "/Pages/Menu"
@model SaleStore.Pages.MenuModel
@{
    Layout = "/Pages/Shared/_PagesLayout.cshtml";
}

<style>
    .line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .product-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .product-card:hover { transform: translateY(-6px); box-shadow: 0 24px 48px rgba(111,78,55,0.18); }
</style>

<!-- Hero Section -->
<section class="bg-gradient-to-r from-[#6F4E37] to-[#2C1810] text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="text-[#D4A574] text-xs font-bold uppercase tracking-[0.2em]">Thực đơn</span>
        <h1 class="text-4xl lg:text-5xl font-bold mt-2 mb-4 serif">Khám phá thức uống</h1>
        <p class="text-xl text-gray-300">Từ cà phê nguyên chất đến thức uống sáng tạo — tất cả đều được pha chế bằng tình yêu.</p>
    </div>
</section>

<!-- Menu Grid -->
<section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Category Filter -->
        <div class="flex flex-wrap justify-center gap-3 mb-10">
            <button onclick="filterCategory(this, 'Tất cả')" class="category-btn px-5 py-2.5 rounded-full border border-[#E8DFD8] text-sm font-semibold text-white bg-[#6F4E37] border-[#6F4E37] transition-all">
                Tất cả
            </button>
            <button onclick="filterCategory(this, 'Cà phê đặc biệt')" class="category-btn px-5 py-2.5 rounded-full border border-[#E8DFD8] text-sm font-semibold text-[#6F4E37] hover:border-[#6F4E37] hover:bg-[#6F4E37] hover:text-white transition-all">
                Cà phê đặc biệt
            </button>
            <button onclick="filterCategory(this, 'Cà phê đá')" class="category-btn px-5 py-2.5 rounded-full border border-[#E8DFD8] text-sm font-semibold text-[#6F4E37] hover:border-[#6F4E37] hover:bg-[#6F4E37] hover:text-white transition-all">
                Cà phê đá
            </button>
            <button onclick="filterCategory(this, 'Cà phê truyền thống')" class="category-btn px-5 py-2.5 rounded-full border border-[#E8DFD8] text-sm font-semibold text-[#6F4E37] hover:border-[#6F4E37] hover:bg-[#6F4E37] hover:text-white transition-all">
                Cà phê truyền thống
            </button>
            <button onclick="filterCategory(this, 'Trà & Khác')" class="category-btn px-5 py-2.5 rounded-full border border-[#E8DFD8] text-sm font-semibold text-[#6F4E37] hover:border-[#6F4E37] hover:bg-[#6F4E37] hover:text-white transition-all">
                Trà & Khác
            </button>
        </div>

        @if (Model.Products == null || !Model.Products.Any())
        {
            <div class="text-center py-12">
                <p class="text-gray-500 text-lg">Chưa có sản phẩm nào trong thực đơn</p>
            </div>
        }
        else
        {
            <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var product in Model.Products)
                {
                    <div class="product-card bg-white rounded-3xl border border-[#E8DFD8] overflow-hidden group" data-category="@product.Category">
                        <!-- Product Image -->
                        <div class="relative h-52 overflow-hidden bg-[#F5EBE0]">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"/>
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center text-6xl">☕</div>
                            }
                            
                            <!-- Category Badge -->
                            <div class="absolute top-3 right-3 bg-white/95 text-[#6F4E37] text-[11px] font-bold px-3 py-1 rounded-full shadow-sm">
                                @product.Category
                            </div>

                            <!-- Stock Badge -->
                            @if (product.Stock <= 0)
                            {
                                <div class="absolute top-3 left-3 bg-red-500 text-white text-[11px] font-bold px-3 py-1 rounded-full">
                                    Hết hàng
                                </div>
                            }
                            else if (product.Stock < 20)
                            {
                                <div class="absolute top-3 left-3 bg-orange-500 text-white text-[11px] font-bold px-3 py-1 rounded-full">
                                    Sắp hết
                                </div>
                            }
                        </div>

                        <!-- Product Info -->
                        <div class="p-5">
                            <h3 class="font-bold text-[#1A0E08] text-base mb-1 serif">@product.Name</h3>
                            @if (!string.IsNullOrEmpty(product.Description))
                            {
                                <p class="text-gray-400 text-xs mb-4 leading-relaxed line-clamp-2">@product.Description</p>
                            }
                            else
                            {
                                <div class="mb-4"></div>
                            }

                            <!-- Price and Add Button -->
                            <div class="flex items-center justify-between">
                                <div>
                                    <span class="product-price text-[#6F4E37] font-bold text-lg" data-price="@product.Price">@product.Price.ToString("N0")</span>
                                    <span class="text-[#8B7355] text-sm ml-0.5">₫</span>
                                </div>
                                <button onclick="addToCart(@product.Id, '@product.Name.Replace("'", "\\'")', @product.Price, '@product.ImageUrl', '@product.Category')"
                                        class="flex items-center gap-1.5 bg-[#6F4E37] hover:bg-[#5D3A1A] active:scale-95 text-white px-4 py-2 rounded-xl text-sm font-semibold transition-all shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
                                        @(product.Stock <= 0 ? "disabled" : "")>
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                                    </svg>
                                    Thêm
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<script>
function filterCategory(button, category) {
    // Update active button
    document.querySelectorAll('.category-btn').forEach(btn => {
        btn.classList.remove('bg-[#6F4E37]', 'text-white', 'border-[#6F4E37]');
        btn.classList.add('text-[#6F4E37]');
    });
    button.classList.add('bg-[#6F4E37]', 'text-white', 'border-[#6F4E37]');
    button.classList.remove('text-[#6F4E37]');

    // Filter products
    const products = document.querySelectorAll('.product-card');
    products.forEach(product => {
        const productCategory = product.getAttribute('data-category');
        if (category === 'Tất cả' || productCategory === category) {
            product.style.display = 'block';
        } else {
            product.style.display = 'none';
        }
    });
}

function addToCart(productId, productName, price, imageUrl, category) {
    // Validate price
    if (!price || price <= 0) {
        console.error('Invalid price:', price);
        showToast('Không thể lấy giá sản phẩm', 'error');
        return;
    }

    const cartItem = {
        productId: productId,
        productName: productName,
        price: price,
        quantity: 1,
        imageUrl: imageUrl || '',
        category: category || ''
    };
    
    console.log('Adding to cart:', cartItem);

    // Send to server
    fetch('/Cart/AddToCart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(cartItem)
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('Network response was not ok');
        }
        return response.json();
    })
    .then(data => {
        console.log('Server response:', data);
        if (data.success) {
            // Show success message with animation
            showToast(`Đã thêm "${productName}" vào giỏ!`, 'success');
            
            // Update cart badge with animation
            updateCartBadge(data.itemCount);
            
            // Add pulse animation to cart button
            const cartBtn = document.querySelector('button[onclick*="openCartSidebar"]');
            if (cartBtn) {
                cartBtn.classList.add('animate-pulse');
                setTimeout(() => cartBtn.classList.remove('animate-pulse'), 1000);
            }
        } else {
            showToast('Không thể thêm vào giỏ hàng: ' + (data.message || 'Unknown error'), 'error');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showToast('Có lỗi xảy ra khi thêm vào giỏ hàng', 'error');
    });
}

function showToast(message, type = 'success') {
    // Remove existing toasts
    const existingToasts = document.querySelectorAll('.toast-notification');
    existingToasts.forEach(t => t.remove());
    
    // Create toast notification
    const toast = document.createElement('div');
    toast.className = `toast-notification fixed top-20 right-4 px-6 py-3 rounded-xl shadow-2xl z-[100] flex items-center gap-3 transform transition-all duration-300 translate-x-0 opacity-100 ${
        type === 'success' ? 'bg-green-500' : 'bg-red-500'
    } text-white font-medium`;
    
    // Add icon
    const icon = document.createElement('span');
    icon.className = 'text-xl';
    icon.textContent = type === 'success' ? '✓' : '✕';
    toast.appendChild(icon);
    
    // Add message
    const messageSpan = document.createElement('span');
    messageSpan.textContent = message;
    toast.appendChild(messageSpan);
    
    document.body.appendChild(toast);
    
    // Animate in
    setTimeout(() => {
        toast.style.transform = 'translateX(0) scale(1.05)';
    }, 10);
    
    setTimeout(() => {
        toast.style.transform = 'translateX(0) scale(1)';
    }, 100);
    
    // Animate out and remove
    setTimeout(() => {
        toast.style.transform = 'translateX(400px)';
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

function updateCartBadge(count) {
    const badge = document.getElementById('cartBadge');
    if (badge) {
        if (count > 0) {
            badge.textContent = count > 9 ? '9+' : count;
            badge.classList.remove('hidden');
            
            // Add bounce animation
            badge.style.animation = 'none';
            setTimeout(() => {
                badge.style.animation = 'bounce 0.5s ease';
            }, 10);
        } else {
            badge.classList.add('hidden');
        }
    }
}

// Add bounce animation using CSS keyframes
const style = document.createElement('style');
const atChar = String.fromCharCode(64);
style.textContent = atChar + 'keyframes bounce { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.3); } }';
document.head.appendChild(style);

// Load cart count on page load
document.addEventListener('DOMContentLoaded', function() {
    fetch('/Cart/GetCart')
        .then(response => response.json())
        .then(data => {
            updateCartBadge(data.itemCount);
        })
        .catch(error => console.error('Error loading cart:', error));
});
</script>

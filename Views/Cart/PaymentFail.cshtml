@{
    Layout = "_Layout";
    ViewData["Title"] = "Thanh toán thất bại";
}

<div class="container py-5 text-center">
    <div class="card border-0 shadow-sm p-5 rounded-2xl mx-auto" style="max-width: 500px;">
        <div class="mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-danger-soft-10 text-danger rounded-circle" style="width: 80px; height: 80px;">
                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </div>
        </div>
        <h1 class="h3 fw-bold text-dark mb-3">Thanh toán không thành công</h1>
        <p class="text-muted mb-4">Rất tiếc, đã có lỗi xảy ra trong quá trình thanh toán hoặc giao dịch bị hủy. Vui lòng thử lại hoặc liên hệ với chúng tôi nếu cần hỗ trợ.</p>
        <div class="d-grid gap-2">
            <a href="/Cart/Checkout" class="btn btn-primary py-3 fw-bold rounded-xl">Thử lại</a>
            <a href="/" class="btn btn-outline-secondary py-3 fw-bold rounded-xl">Quay lại trang chủ</a>
        </div>
    </div>
</div>

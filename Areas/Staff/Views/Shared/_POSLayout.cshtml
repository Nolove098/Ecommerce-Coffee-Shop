<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SaleStore POS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .serif { font-family: 'Playfair Display', serif; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-thumb { background: #D4A574; border-radius: 999px; }
        .pos-shell { background: linear-gradient(135deg, #F8F2EC 0%, #FAF8F5 52%, #F0E4D7 100%); }
    </style>
</head>
<body class="pos-shell text-[#1A0E08] min-h-screen overflow-hidden">
    <div class="h-screen flex flex-col">
        <header class="border-b border-[#E8DFD8] bg-white/85 backdrop-blur-lg px-6 py-4 flex items-center justify-between gap-4 flex-shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 bg-[#6F4E37] rounded-2xl flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-[#F7E8D5]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z" />
                        <line x1="6" y1="1" x2="6" y2="4" /><line x1="10" y1="1" x2="10" y2="4" /><line x1="14" y1="1" x2="14" y2="4" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#8B7355]">Point of Sale</p>
                    <h1 class="text-2xl font-bold serif text-[#6F4E37]">@(ViewData["Title"] ?? "POS")</h1>
                </div>
            </div>

            <div class="flex items-center gap-3">
                @if (User.IsInRole(SaleStore.Models.AppRoles.Admin))
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center gap-2 rounded-2xl border border-[#E8DFD8] bg-[#FAF8F5] px-4 py-2.5 text-sm font-semibold text-[#6F4E37] hover:bg-[#F5EBE0] transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg>
                        Admin Dashboard
                    </a>
                }
                <a asp-area="" asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-2 rounded-2xl border border-[#E8DFD8] bg-white px-4 py-2.5 text-sm font-semibold text-[#6F4E37] hover:bg-[#FAF8F5] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    Website
                </a>
                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-2xl bg-[#6F4E37] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#5D3A1A] transition-colors">Đăng xuất</button>
                </form>
            </div>
        </header>

        <main class="flex-1 overflow-hidden">
            @RenderBody()
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
@{
    var inventoryItems = new[] {
        new { Name = "Coffee Beans", Icon = "coffee", Stock = 245, Unit = "kg", Status = "good", StatusColor = "bg-green-100 text-green-700", Progress = 82, ProgressColor = "bg-green-500" },
        new { Name = "Milk", Icon = "milk", Stock = 128, Unit = "L", Status = "good", StatusColor = "bg-green-100 text-green-700", Progress = 64, ProgressColor = "bg-green-500" },
        new { Name = "Pastries", Icon = "cookie", Stock = 45, Unit = "items", Status = "low", StatusColor = "bg-orange-100 text-orange-700", Progress = 30, ProgressColor = "bg-orange-500" },
        new { Name = "Cups & Lids", Icon = "coffee", Stock = 892, Unit = "pcs", Status = "good", StatusColor = "bg-green-100 text-green-700", Progress = 89, ProgressColor = "bg-green-500" }
    };
}

<div class="mt-6">
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-[#6F4E37]">Inventory Status</h3>
        <button class="text-sm text-[#6F4E37] hover:text-[#8B7355] font-medium">
            View All &rarr;
        </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        @foreach (var item in inventoryItems)
        {
            <div class="bg-white p-6 rounded-3xl border border-[#E8DFD8] shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-start justify-between mb-4">
                    <div class="w-12 h-12 bg-gradient-to-br from-[#6F4E37] to-[#8B7355] rounded-2xl flex items-center justify-center">
                        @if (item.Icon == "coffee")
                        {
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
                                <line x1="6" y1="1" x2="6" y2="4"></line>
                                <line x1="10" y1="1" x2="10" y2="4"></line>
                                <line x1="14" y1="1" x2="14" y2="4"></line>
                            </svg>
                        }
                        else if (item.Icon == "milk")
                        {
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <path d="M8 2h8"/>
                                <path d="M9 2v2.789a4 4 0 0 1-.672 2.219l-2.656 3.984A4 4 0 0 0 5 13.212V20a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6.789a4 4 0 0 0-.672-2.219l-2.656-3.984A4 4 0 0 1 15 4.788V2"/>
                            </svg>
                        }
                        else if (item.Icon == "cookie")
                        {
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/>
                                <path d="M8.5 8.5v.01"/>
                                <path d="M16 15.5v.01"/>
                                <path d="M12 12v.01"/>
                                <path d="M11 17v.01"/>
                                <path d="M7 14v.01"/>
                            </svg>
                        }
                    </div>
                    <span class="px-3 py-1 rounded-full text-xs font-medium @item.StatusColor">
                        @if (item.Status == "low")
                        {
                            <span class="flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="12"></line>
                                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                </svg>
                                Low Stock
                            </span>
                        }
                        else
                        {
                            @:In Stock
                        }
                    </span>
                </div>

                <h4 class="text-[#6F4E37] font-bold text-lg mb-1">@item.Name</h4>
                <p class="text-2xl font-bold text-[#6F4E37] mb-4">
                    @item.Stock <span class="text-sm text-[#8B7355] font-normal">@item.Unit</span>
                </p>

                <div class="space-y-2">
                    <div class="flex justify-between text-xs text-[#8B7355]">
                        <span>Stock Level</span>
                        <span>@item.Progress%</span>
                    </div>
                    <div class="w-full bg-[#F5EBE0] rounded-full h-2 overflow-hidden">
                        <div class="h-full @item.ProgressColor rounded-full transition-all"
                             style="width: @(item.Progress)%">
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@inject IServiceScopeFactory ScopeFactory
@inject Microsoft.AspNetCore.SignalR.IHubContext<SaleStore.Hubs.OrderHub> HubContext

<div class="card shadow-soft h-100">
    <div class="card-body p-4">
        <h4 class="small fw-bold text-coffee text-uppercase mb-3">Cập nhật trạng thái</h4>
        <div class="d-flex gap-2">
            <select class="form-select flex-grow-1" @bind="selectedStatusValue" disabled="@isUpdating">
                @foreach (var s in allStatuses)
                {
                    <option value="@s.ToString()">@s.ToVietnamese()</option>
                }
            </select>
            <button class="btn btn-coffee text-nowrap" type="button" disabled="@(isUpdating || selectedStatusValue == currentStatus.ToString())" @onclick="ApplyStatus">
                @if (isUpdating)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                }
                Cập nhật
            </button>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @(isError ? "alert-danger" : "alert-success") d-flex align-items-center gap-2 py-2 mt-3 mb-0 small" role="alert">
                @if (isError)
                {
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                }
                else
                {
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
                }
                <span>@message</span>
            </div>
        }
    </div>
</div>

<style>
    .btn-coffee {
        background-color: #6F4E37;
        border-color: #6F4E37;
        color: #fff;
    }

    .btn-coffee:hover,
    .btn-coffee:focus {
        background-color: #5D3A1A;
        border-color: #5D3A1A;
        color: #fff;
    }

    .btn-coffee:disabled {
        background-color: #9c7f68;
        border-color: #9c7f68;
        color: #f8f9fa;
    }
</style>

@code {
    [Parameter]
    public long OrderId { get; set; }

    [Parameter]
    public string InitialStatus { get; set; } = nameof(OrderStatus.Pending);

    private OrderStatus currentStatus;
    private OrderStatus[] allStatuses = new[] { OrderStatus.Pending, OrderStatus.Ready, OrderStatus.Delivered, OrderStatus.Cancelled };
    private string message = "";
    private bool isError;
    private bool isUpdating;

    protected override void OnParametersSet()
    {
        if (Enum.TryParse<OrderStatus>(InitialStatus, out var parsed))
        {
            currentStatus = parsed;
            selectedStatusValue = parsed.ToString();
        }
    }

    private string selectedStatusValue = nameof(OrderStatus.Pending);

    protected override void OnInitialized()
    {
        selectedStatusValue = currentStatus.ToString();
    }

    private async Task ApplyStatus()
    {
        if (isUpdating || selectedStatusValue == currentStatus.ToString())
            return;

        if (!Enum.TryParse<OrderStatus>(selectedStatusValue, out var newStatus))
            return;

        await ChangeStatus(newStatus);
    }

    private async Task ChangeStatus(OrderStatus newStatus)
    {
        if (isUpdating)
            return;

        isUpdating = true;
        message = "";
        isError = false;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
            var order = await db.Orders.FindAsync(OrderId);

            if (order == null)
            {
                message = "Không tìm thấy đơn hàng.";
                isError = true;
                return;
            }

            order.Status = newStatus;
            await db.SaveChangesAsync();
            currentStatus = newStatus;
            selectedStatusValue = newStatus.ToString();
            message = $"Đã cập nhật thành \"{newStatus.ToVietnamese()}\" thành công!";

            // Broadcast real-time update via SignalR
            await HubContext.Clients.Group($"order-{OrderId}").SendAsync("OrderStatusChanged", OrderId, newStatus.ToString(), newStatus.ToVietnamese());
            await HubContext.Clients.Group("admin-dashboard").SendAsync("OrderUpdated", OrderId, newStatus.ToString(), newStatus.ToVietnamese());
        }
        catch
        {
            message = "Có lỗi xảy ra khi cập nhật trạng thái.";
            isError = true;
        }
        finally
        {
            isUpdating = false;
        }
    }
}

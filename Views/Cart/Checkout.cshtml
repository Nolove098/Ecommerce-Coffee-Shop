@model SaleStore.Models.ViewModels.CheckoutViewModel
@{
    Layout = null;
    ViewData["Title"] = "Thanh toán – SaleStore";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Thanh toán – SaleStore</title>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    
    <!-- Custom CSS -->
    <link href="~/css/custom.css" rel="stylesheet"/>
</head>
<body class="bg-cream min-vh-100">

<!-- Header -->
<header class="bg-dark shadow-lg">
    <div class="container" style="max-width: 1200px;">
        <div class="d-flex align-items-center justify-content-between py-3 px-3 px-md-0">
            <a href="/" class="d-flex align-items-center gap-3 text-decoration-none">
                <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl" style="width: 36px; height: 36px;">
                    <svg class="text-dark" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                        <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                    </svg>
                </div>
                <span class="text-white fw-bold fs-5 serif">SaleStore</span>
            </a>
            <!-- Breadcrumb -->
            <nav class="d-none d-md-flex" aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="/" class="text-white-50 text-decoration-none">Trang chủ</a></li>
                    <li class="breadcrumb-item active text-caramel" aria-current="page">Thanh toán</li>
                </ol>
            </nav>
        </div>
    </div>
</header>

<main class="container py-5" style="max-width: 1200px;">
    <h1 class="fs-2 fw-bold text-dark mb-4 serif">Thanh toán đơn hàng</h1>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <strong>Lỗi!</strong> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-area="" asp-action="PlaceOrder" asp-controller="Cart" method="post" id="checkoutForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CartJson" id="cartJsonInput"/>

        <div class="row g-4">

            <!-- ===== LEFT: Form ===== -->
            <div class="col-12 col-lg-7">
                <div class="mb-4">
                    <div class="card border rounded-2xl shadow-sm">
                        <div class="card-body p-4">
                            <h2 class="card-title h6 fw-bold text-coffee text-uppercase mb-4 d-flex align-items-center gap-2">
                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                Thông tin khách hàng
                            </h2>

                            <div class="row g-3">
                                <!-- Name -->
                                <div class="col-12">
                                    <label asp-for="CustomerName" class="form-label small fw-semibold text-coffee">
                                        Họ và tên <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="CustomerName" placeholder="Nguyễn Văn A" class="form-control"/>
                                    <span asp-validation-for="CustomerName" class="invalid-feedback d-block"></span>
                                </div>

                                <!-- Phone -->
                                <div class="col-12">
                                    <label asp-for="CustomerPhone" class="form-label small fw-semibold text-coffee">
                                        Số điện thoại <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="CustomerPhone" placeholder="0901 234 567" type="tel" class="form-control"/>
                                    <span asp-validation-for="CustomerPhone" class="invalid-feedback d-block"></span>
                                </div>

                                <!-- Address -->
                                <div class="col-12">
                                    <label asp-for="Address" class="form-label small fw-semibold text-coffee">
                                        Địa chỉ giao hàng
                                    </label>
                                    <input asp-for="Address" placeholder="123 Đường ABC, Quận 1, TP.HCM" class="form-control"/>
                                </div>

                                <!-- Note -->
                                <div class="col-12">
                                    <label asp-for="Note" class="form-label small fw-semibold text-coffee">
                                        Ghi chú
                                    </label>
                                    <textarea asp-for="Note" rows="3" placeholder="Ít đường, không đá, v.v..." class="form-control"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment method (display only) -->
                <div class="card border rounded-2xl shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="card-title h6 fw-bold text-coffee text-uppercase mb-3 d-flex align-items-center gap-2">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                            </svg>
                            Phương thức thanh toán
                        </h2>
                        <div class="d-flex align-items-center gap-3 bg-cream border border-secondary rounded-2xl p-3">
                            <div class="d-flex align-items-center justify-content-center rounded-xl bg-secondary-soft-20" style="width: 40px; height: 40px;">
                                <svg class="text-caramel" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                                </svg>
                            </div>
                            <div class="flex-grow-1">
                                <p class="fw-semibold text-coffee small mb-0">Thanh toán khi nhận hàng (COD)</p>
                                <p class="text-muted-custom mb-0" style="font-size: 0.75rem;">Thanh toán bằng tiền mặt khi nhận đơn</p>
                            </div>
                            <div class="d-flex align-items-center justify-content-center border border-2 border-secondary rounded-circle" style="width: 20px; height: 20px;">
                                <div class="bg-secondary rounded-circle" style="width: 10px; height: 10px;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== RIGHT: Order Summary ===== -->
            <div class="col-12 col-lg-5">
                <div class="card border rounded-2xl shadow-sm position-sticky" style="top: 1.5rem;">
                    <div class="card-header bg-cream border-bottom p-4">
                        <h2 class="h6 fw-bold text-coffee mb-0">Đơn hàng của bạn</h2>
                    </div>

                    <div id="orderSummaryItems" class="card-body p-4" style="max-height: 340px; overflow-y: auto;">
                        <!-- Populated by JS -->
                        <p class="text-muted text-center py-4 mb-0">Đang tải giỏ hàng...</p>
                    </div>

                    <div id="orderSummaryEmpty" class="card-body p-4 text-center d-none">
                        <p class="text-muted-custom small mb-0">Giỏ hàng trống.</p>
                        <a href="/" class="d-inline-block mt-3 text-coffee small fw-semibold text-decoration-none">← Quay lại chọn món</a>
                    </div>

                    <div class="card-footer bg-white border-top p-4">
                        <div class="d-flex justify-content-between small text-muted-custom mb-2">
                            <span>Tạm tính</span>
                            <span id="subtotalDisplay">0 ₫</span>
                        </div>
                        <div class="d-flex justify-content-between small text-muted-custom mb-3">
                            <span>Phí giao hàng</span>
                            <span class="text-success fw-semibold">Miễn phí</span>
                        </div>
                        <div class="d-flex justify-content-between fw-bold text-dark fs-5 border-top pt-3 mb-3">
                            <span>Tổng cộng</span>
                            <span id="totalDisplay" class="text-coffee">0 ₫</span>
                        </div>
                        <button type="submit" id="placeOrderBtn" class="btn btn-primary w-100 py-3 fw-bold d-flex align-items-center justify-content-center gap-2 shadow-lg">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                            Đặt hàng ngay
                        </button>
                        <a href="/" class="d-block text-center small text-muted-custom text-decoration-none mt-2">← Thêm món khác</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</main>

<script>
    const CART_KEY = 'ss_cart_v1';
    function getCart() {
        try { return JSON.parse(localStorage.getItem(CART_KEY)) || []; }
        catch { return []; }
    }

    const cart = getCart();
    const summaryEl = document.getElementById('orderSummaryItems');
    const emptyEl   = document.getElementById('orderSummaryEmpty');
    const subtotalEl = document.getElementById('subtotalDisplay');
    const totalEl   = document.getElementById('totalDisplay');
    const cartInput = document.getElementById('cartJsonInput');
    const btn       = document.getElementById('placeOrderBtn');

    if (cart.length === 0) {
        summaryEl.classList.add('d-none');
        emptyEl.classList.remove('d-none');
        btn.disabled = true;
    } else {
        const total = cart.reduce((s, i) => s + i.price * i.quantity, 0);
        subtotalEl.textContent = total.toLocaleString('vi-VN') + ' ₫';
        totalEl.textContent    = total.toLocaleString('vi-VN') + ' ₫';
        cartInput.value = JSON.stringify(cart);

        summaryEl.innerHTML = cart.map(item => `
            <div class="d-flex align-items-center gap-3 mb-3">
                ${item.imageUrl
                    ? `<img src="${item.imageUrl}" alt="${item.productName}" class="rounded-xl object-fit-cover flex-shrink-0" style="width: 56px; height: 56px;"/>`
                    : `<div class="rounded-xl bg-light-brown d-flex align-items-center justify-content-center flex-shrink-0 fs-4" style="width: 56px; height: 56px;">☕</div>`}
                <div class="flex-grow-1 overflow-hidden">
                    <p class="fw-semibold text-dark small mb-0 text-truncate">${item.productName}</p>
                    <p class="text-muted-custom mb-0" style="font-size: 0.75rem;">x${item.quantity}</p>
                </div>
                <p class="fw-bold text-coffee small mb-0 flex-shrink-0">${(item.price * item.quantity).toLocaleString('vi-VN')} ₫</p>
            </div>
        `).join('<hr class="my-2 border-light-brown">');
    }
</script>

<!-- Bootstrap 5.3 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>

</body>
</html>

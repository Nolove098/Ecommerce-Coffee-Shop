@model List<SaleStore.Models.Order>
@using SaleStore.Models
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Lịch sử đơn hàng – SaleStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="~/css/custom.css" rel="stylesheet"/>
</head>
<body class="bg-cream">

<!-- Header -->
<nav class="navbar bg-dark-brown">
    <div class="container" style="max-width: 960px;">
        <a href="/" class="navbar-brand d-flex align-items-center gap-2">
            <div class="d-flex align-items-center justify-content-center bg-secondary rounded-xl" style="width: 36px; height: 36px;">
                <svg class="text-dark" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <span class="text-white fw-bold fs-5 serif">SaleStore</span>
        </a>
        <a href="/" class="btn btn-outline-light btn-sm rounded-xl">← Trang chủ</a>
    </div>
</nav>

<div class="container py-5" style="max-width: 960px;">
    <div class="text-center mb-5">
        <h1 class="display-6 fw-bold text-dark serif">Đơn hàng của tôi</h1>
        <p class="text-muted">Theo dõi trạng thái và lịch sử đặt hàng</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-3 mb-3">📦</div>
            <p class="text-muted fw-medium mb-2">Bạn chưa có đơn hàng nào</p>
            <p class="text-muted small">Hãy đặt thức uống yêu thích ngay!</p>
            <a href="/" class="btn btn-primary rounded-xl mt-3">Xem thực đơn</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="card border rounded-4 shadow-sm overflow-hidden">
                        <div class="card-body p-4">
                            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-3">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h5 class="fw-bold text-dark mb-0 font-monospace">Đơn #@order.Id.ToString("D4")</h5>
                                        <span class="badge @order.Status.ToBadgeClass()">@order.Status.ToVietnamese()</span>
                                    </div>
                                    <p class="text-muted small mb-0">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="me-1"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        @order.CreatedAt.AddHours(7).ToString("HH:mm - dd/MM/yyyy")
                                    </p>
                                </div>
                                <div class="text-end">
                                    <p class="fs-5 fw-bold text-primary mb-0">@order.TotalAmount.ToString("N0") ₫</p>
                                    <p class="text-muted small mb-0">@order.OrderItems.Count sản phẩm</p>
                                </div>
                            </div>

                            <!-- Items preview -->
                            <div class="bg-cream rounded-3 p-3 mb-3">
                                <p class="small text-muted mb-0">
                                    @string.Join(" · ", order.OrderItems.Select(i => $"{i.ProductName} ×{i.Quantity}"))
                                </p>
                            </div>

                            <!-- Status timeline -->
                            <div class="d-flex align-items-center gap-2 mb-3">
                                @{
                                    var steps = new[] {
                                        (Status: OrderStatus.Pending, Label: "Chờ xử lý", Icon: "⏳"),
                                        (Status: OrderStatus.Ready, Label: "Sẵn sàng", Icon: "✅"),
                                        (Status: OrderStatus.Delivered, Label: "Đã giao", Icon: "🎉")
                                    };
                                    var isCancelled = order.Status == OrderStatus.Cancelled;
                                }
                                @if (isCancelled)
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2">❌ Đã hủy</span>
                                }
                                else
                                {
                                    @foreach (var (step, idx) in steps.Select((s, i) => (s, i)))
                                    {
                                        var isActive = (int)order.Status >= (int)step.Status;
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="rounded-circle d-flex align-items-center justify-content-center @(isActive ? "bg-primary text-white" : "bg-light text-muted")" style="width: 28px; height: 28px; font-size: 12px;">
                                                @step.Icon
                                            </span>
                                            <span class="small @(isActive ? "fw-semibold text-primary" : "text-muted")">@step.Label</span>
                                        </div>
                                        @if (idx < steps.Length - 1)
                                        {
                                            <div class="flex-grow-1 border-top @(isActive && (int)order.Status > (int)step.Status ? "border-primary" : "border-secondary border-opacity-25")" style="height: 0;"></div>
                                        }
                                    }
                                }
                            </div>

                            <a asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id"
                               class="btn btn-outline-primary btn-sm rounded-xl">
                                Xem chi tiết →
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
</body>
</html>

@{
    var today = DateTime.Now.ToString("dddd, MMMM dd, yyyy");
}

<header class="bg-white border-b border- px-8 py-4">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-[#6F4E37]">Dashboard Overview</h2>
            <div class="flex items-center gap-2 mt-1 text-sm text-[#8B7355]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <span>@today</span>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <!-- Search -->
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-[#8B7355]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <input
                    type="text"
                    placeholder="Search..."
                    class="pl-10 pr-4 py-2 w-80 bg-[#FAF8F5] border border-[#E8DFD8] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#D4A574] text-[#6F4E37] placeholder:text-[#8B7355]/50"
                />
            </div>

            <!-- Notifications -->
            <button class="relative p-2 hover:bg-[#FAF8F5] rounded-xl transition-colors">
                <svg class="w-6 h-6 text-[#6F4E37]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                </svg>
                <span class="absolute top-1 right-1 w-2 h-2 bg-[#D4A574] rounded-full"></span>
            </button>
        </div>
    </div>
</header>

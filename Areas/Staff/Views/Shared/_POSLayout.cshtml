<!--
    POS Layout - SaleStore Staff Point of Sale Area
    
    Bootstrap Version: 5.3.8
    
    This layout provides the structure for the Point of Sale (POS) interface used by staff members.
    It implements a full-height layout optimized for tablet and desktop use in a retail environment.
    
    Key Bootstrap Components Used:
    - Grid System: d-flex, flex-column for vertical layout structure
    - Utilities: vh-100, overflow-hidden for full-height, no-scroll container
    - Spacing: px-4, py-3, gap-3 for consistent spacing
    - Colors: bg-gradient-pos (custom gradient), bg-white for header
    
    Layout Structure:
    - Header: Fixed height navigation bar with branding, navigation links, and logout
    - Main: Flexible height content area for POS interface (product grid and cart)
    
    Responsive Behavior:
    - Optimized for tablet (768px+) and desktop use
    - Header remains fixed at top with flex-shrink-0
    - Main content area scrolls independently
-->
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SaleStore POS</title>
    
    <!-- Google Fonts Preconnect: Improves font loading performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Google Fonts: Inter for body text, Playfair Display for headings -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5.3.8 CSS: Core framework styles loaded from CDN with integrity hash for security -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    
    <!-- Custom CSS: Loaded after Bootstrap to override default styles with coffee-themed brand colors -->
    <link rel="stylesheet" href="~/css/custom.css" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="bg-gradient-pos min-vh-100 overflow-hidden text-dark-brown">
    <!-- 
        Main Layout Container
        vh-100: Full viewport height
        d-flex flex-column: Vertical flexbox layout (header stacked on top of main)
    -->
    <div class="vh-100 d-flex flex-column">
        <!-- 
            Header Navigation Bar
            Fixed height header with branding, navigation, and user actions.
            flex-shrink-0: Prevents header from shrinking when content overflows
            backdrop-filter: Creates frosted glass effect (modern browsers)
            
            Bootstrap Classes Used:
            - border-bottom: Bottom border separator
            - px-4 py-3: Horizontal and vertical padding
            - d-flex: Flexbox container
            - align-items-center: Vertical centering
            - justify-content-between: Space between left and right sections
            - gap-3: Spacing between flex items
        -->
        <header class="border-bottom bg-white px-4 py-3 d-flex align-items-center justify-content-between gap-3 flex-shrink-0 border-light-brown" style="backdrop-filter: blur(10px); background-color: rgba(255, 255, 255, 0.85);">
            <!-- Left section: POS branding and title -->
            <div class="d-flex align-items-center gap-3">
                <!-- Coffee cup icon with gradient background -->
                <div class="d-flex align-items-center justify-content-center rounded-2xl shadow-medium bg-primary" style="width: 2.75rem; height: 2.75rem;">
                    <svg class="text-white" style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z" />
                        <line x1="6" y1="1" x2="6" y2="4" /><line x1="10" y1="1" x2="10" y2="4" /><line x1="14" y1="1" x2="14" y2="4" />
                    </svg>
                </div>
                <div>
                    <p class="text-uppercase small fw-bold text-muted-custom mb-0" style="letter-spacing: 0.22em;">Point of Sale</p>
                    <h1 class="h4 fw-bold serif text-coffee mb-0">@(ViewData["Title"] ?? "POS")</h1>
                </div>
            </div>

            <!-- 
                Right section: Navigation links and logout
                Conditional rendering based on user role (Admin sees additional link)
                
                Bootstrap Button Classes:
                - btn-outline-primary: Outlined button with primary color border
                - btn-primary: Solid button with primary background
                - btn-sm: Small button size
                - rounded-2xl: Custom rounded corners (defined in custom.css)
                - d-inline-flex: Inline flexbox for icon + text alignment
                - align-items-center: Vertical centering of icon and text
                - gap-2: Spacing between icon and text
            -->
            <div class="d-flex align-items-center gap-2">
                <!-- Admin Dashboard link (only visible to Admin role) -->
                @if (User.IsInRole(SaleStore.Models.AppRoles.Admin))
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-2xl d-inline-flex align-items-center gap-2">
                        <svg style="width: 1rem; height: 1rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg>
                        Admin Dashboard
                    </a>
                }
                <!-- Website link (returns to public-facing site) -->
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-2xl d-inline-flex align-items-center gap-2">
                    <svg style="width: 1rem; height: 1rem;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    Website
                </a>
                <!-- Logout form (POST request for security) -->
                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                    <button type="submit" class="btn btn-primary btn-sm rounded-2xl d-inline-flex align-items-center gap-2">Đăng xuất</button>
                </form>
            </div>
        </header>

        <!-- 
            Main Content Area
            flex-fill: Takes remaining vertical space after header
            overflow-hidden: Prevents scrolling on this container (child elements handle scrolling)
            This is where page-specific POS content (@RenderBody()) is displayed
        -->
        <main class="flex-fill overflow-hidden">
            @RenderBody()
        </main>
    </div>

    <!-- 
        Bootstrap 5.3.8 JavaScript Bundle
        Includes Bootstrap core JS and Popper.js for interactive components.
        Loaded at end of body for optimal page load performance.
        Integrity hash ensures CDN file hasn't been tampered with.
    -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    
    <!-- 
        Bootstrap Component Initialization
        Custom script that initializes Bootstrap components after DOM load.
        Handles tooltips, modals, dropdowns, and other interactive components.
    -->
    <script src="~/js/bootstrap-init.js"></script>
    
    <!-- Optional page-specific scripts -->
    @RenderSection("Scripts", required: false)
</body>
</html>
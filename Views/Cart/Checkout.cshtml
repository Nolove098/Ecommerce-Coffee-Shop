@model SaleStore.Models.ViewModels.CheckoutViewModel
@{
    Layout = null;
    ViewData["Title"] = "Thanh toán – SaleStore";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Thanh toán – SaleStore</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .serif { font-family: 'Playfair Display', serif; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: #D4A574; border-radius: 3px; }
    </style>
</head>
<body class="bg-[#FAF8F5] min-h-screen">

<!-- Header -->
<header class="bg-[#1A0E08] shadow-xl">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
            <div class="w-9 h-9 bg-[#D4A574] rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-[#1A0E08]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <span class="text-white font-bold text-lg serif">SaleStore</span>
        </a>
        <!-- Breadcrumb -->
        <div class="hidden md:flex items-center gap-2 text-sm">
            <a href="/" class="text-white/50 hover:text-white transition-colors">Trang chủ</a>
            <span class="text-white/30">›</span>
            <span class="text-[#D4A574] font-semibold">Thanh toán</span>
        </div>
    </div>
</header>

<main class="max-w-5xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-[#1A0E08] mb-8 serif">Thanh toán đơn hàng</h1>

    @if (ViewBag.Error != null)
    {
        <div class="bg-red-50 border border-red-200 rounded-2xl p-4 mb-6 text-red-700 text-sm">
            @ViewBag.Error
        </div>
    }

    <form asp-area="" asp-action="PlaceOrder" asp-controller="Cart" method="post" id="checkoutForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CartJson" id="cartJsonInput"/>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

            <!-- ===== LEFT: Form ===== -->
            <div class="lg:col-span-3 space-y-5">
                <div class="bg-white rounded-3xl border border-[#E8DFD8] p-7 shadow-sm">
                    <h2 class="text-base font-bold text-[#6F4E37] uppercase tracking-wide mb-5 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        Thông tin khách hàng
                    </h2>

                    <div class="space-y-4">
                        <!-- Name -->
                        <div>
                            <label asp-for="CustomerName" class="block text-sm font-semibold text-[#6F4E37] mb-1.5">
                                Họ và tên <span class="text-red-500">*</span>
                            </label>
                            <input asp-for="CustomerName" placeholder="Nguyễn Văn A"
                                   class="w-full border border-[#E8DFD8] rounded-xl px-4 py-3 text-sm text-[#1A0E08] focus:border-[#D4A574] focus:ring-2 focus:ring-[#D4A574]/30 outline-none transition-all bg-[#FDFAF8]"/>
                            <span asp-validation-for="CustomerName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <!-- Phone -->
                        <div>
                            <label asp-for="CustomerPhone" class="block text-sm font-semibold text-[#6F4E37] mb-1.5">
                                Số điện thoại <span class="text-red-500">*</span>
                            </label>
                            <input asp-for="CustomerPhone" placeholder="0901 234 567" type="tel"
                                   class="w-full border border-[#E8DFD8] rounded-xl px-4 py-3 text-sm text-[#1A0E08] focus:border-[#D4A574] focus:ring-2 focus:ring-[#D4A574]/30 outline-none transition-all bg-[#FDFAF8]"/>
                            <span asp-validation-for="CustomerPhone" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <!-- Address -->
                        <div>
                            <label asp-for="Address" class="block text-sm font-semibold text-[#6F4E37] mb-1.5">
                                Địa chỉ giao hàng
                            </label>
                            <input asp-for="Address" placeholder="123 Đường ABC, Quận 1, TP.HCM"
                                   class="w-full border border-[#E8DFD8] rounded-xl px-4 py-3 text-sm text-[#1A0E08] focus:border-[#D4A574] focus:ring-2 focus:ring-[#D4A574]/30 outline-none transition-all bg-[#FDFAF8]"/>
                        </div>

                        <!-- Note -->
                        <div>
                            <label asp-for="Note" class="block text-sm font-semibold text-[#6F4E37] mb-1.5">
                                Ghi chú
                            </label>
                            <textarea asp-for="Note" rows="3" placeholder="Ít đường, không đá, v.v..."
                                      class="w-full border border-[#E8DFD8] rounded-xl px-4 py-3 text-sm text-[#1A0E08] focus:border-[#D4A574] focus:ring-2 focus:ring-[#D4A574]/30 outline-none transition-all resize-none bg-[#FDFAF8]"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Payment method (display only) -->
                <div class="bg-white rounded-3xl border border-[#E8DFD8] p-7 shadow-sm">
                    <h2 class="text-base font-bold text-[#6F4E37] uppercase tracking-wide mb-4 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                        Phương thức thanh toán
                    </h2>
                    <div class="flex items-center gap-3 bg-[#FAF8F5] border border-[#D4A574] rounded-2xl p-4">
                        <div class="w-10 h-10 bg-[#D4A574]/20 rounded-xl flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#D4A574]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        </div>
                        <div>
                            <p class="font-semibold text-[#6F4E37] text-sm">Thanh toán khi nhận hàng (COD)</p>
                            <p class="text-xs text-[#8B7355]">Thanh toán bằng tiền mặt khi nhận đơn</p>
                        </div>
                        <div class="ml-auto w-5 h-5 border-2 border-[#D4A574] rounded-full flex items-center justify-center">
                            <div class="w-2.5 h-2.5 bg-[#D4A574] rounded-full"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== RIGHT: Order Summary ===== -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-3xl border border-[#E8DFD8] shadow-sm sticky top-6 overflow-hidden">
                    <div class="px-6 py-5 border-b border-[#E8DFD8] bg-[#FAF8F5]">
                        <h2 class="text-base font-bold text-[#6F4E37]">Đơn hàng của bạn</h2>
                    </div>

                    <div id="orderSummaryItems" class="px-6 py-4 space-y-4 max-h-[340px] overflow-y-auto">
                        <!-- Populated by JS -->
                        <p class="text-gray-400 text-sm text-center py-4">Đang tải giỏ hàng...</p>
                    </div>

                    <div id="orderSummaryEmpty" class="px-6 py-8 text-center hidden">
                        <p class="text-[#8B7355] text-sm">Giỏ hàng trống.</p>
                        <a href="/" class="inline-block mt-3 text-[#6F4E37] text-sm font-semibold hover:underline">← Quay lại chọn món</a>
                    </div>

                    <div class="px-6 pb-6 border-t border-[#E8DFD8] pt-5 space-y-3">
                        <div class="flex justify-between text-sm text-[#8B7355]">
                            <span>Tạm tính</span>
                            <span id="subtotalDisplay">0 ₫</span>
                        </div>
                        <div class="flex justify-between text-sm text-[#8B7355]">
                            <span>Phí giao hàng</span>
                            <span class="text-green-600 font-semibold">Miễn phí</span>
                        </div>
                        <div class="flex justify-between font-bold text-[#1A0E08] text-lg border-t border-[#E8DFD8] pt-3">
                            <span>Tổng cộng</span>
                            <span id="totalDisplay" class="text-[#6F4E37]">0 ₫</span>
                        </div>
                        <button type="submit" id="placeOrderBtn"
                                class="w-full mt-2 bg-[#6F4E37] hover:bg-[#5D3A1A] text-white py-4 rounded-2xl font-bold text-base transition-colors shadow-xl flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            Đặt hàng ngay
                        </button>
                        <a href="/" class="block text-center text-sm text-[#8B7355] hover:text-[#6F4E37] transition-colors mt-1">← Thêm món khác</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</main>

<script>
    const CART_KEY = 'ss_cart_v1';
    function getCart() {
        try { return JSON.parse(localStorage.getItem(CART_KEY)) || []; }
        catch { return []; }
    }

    const cart = getCart();
    const summaryEl = document.getElementById('orderSummaryItems');
    const emptyEl   = document.getElementById('orderSummaryEmpty');
    const subtotalEl = document.getElementById('subtotalDisplay');
    const totalEl   = document.getElementById('totalDisplay');
    const cartInput = document.getElementById('cartJsonInput');
    const btn       = document.getElementById('placeOrderBtn');

    if (cart.length === 0) {
        summaryEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        btn.disabled = true;
    } else {
        const total = cart.reduce((s, i) => s + i.price * i.quantity, 0);
        subtotalEl.textContent = total.toLocaleString('vi-VN') + ' ₫';
        totalEl.textContent    = total.toLocaleString('vi-VN') + ' ₫';
        cartInput.value = JSON.stringify(cart);

        summaryEl.innerHTML = cart.map(item => `
            <div class="flex items-center gap-3">
                ${item.imageUrl
                    ? `<img src="${item.imageUrl}" alt="${item.productName}" class="w-14 h-14 rounded-xl object-cover flex-shrink-0"/>`
                    : `<div class="w-14 h-14 rounded-xl bg-[#F5EBE0] flex items-center justify-center text-xl flex-shrink-0">☕</div>`}
                <div class="flex-1 min-w-0">
                    <p class="font-semibold text-[#1A0E08] text-sm truncate">${item.productName}</p>
                    <p class="text-xs text-[#8B7355]">x${item.quantity}</p>
                </div>
                <p class="font-bold text-[#6F4E37] text-sm flex-shrink-0">${(item.price * item.quantity).toLocaleString('vi-VN')} ₫</p>
            </div>
        `).join('<div class="border-t border-[#F5EBE0]"></div>');
    }
</script>

</body>
</html>

@model List<SaleStore.Models.Order>
@using SaleStore.Models
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    var statuses = Enum.GetValues<OrderStatus>();
    var currentStatus = ViewBag.CurrentStatus as string ?? "";
}

<!-- Filter tabs -->
<div class="d-flex align-items-center gap-2 mb-4 flex-wrap">
    <a asp-area="Admin" asp-controller="Order" asp-action="Index"
       class="btn btn-sm rounded-xl @(string.IsNullOrEmpty(currentStatus) ? "btn-primary" : "btn-outline-primary")">
        Tất cả
        <span class="badge rounded-pill @(string.IsNullOrEmpty(currentStatus) ? "bg-white bg-opacity-25 text-white" : "bg-light-brown") ms-2">@Model.Count</span>
    </a>
    @foreach (var s in statuses)
    {
        var count = Model.Count(o => o.Status == s);
        var isActive = currentStatus == s.ToString();
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-status="@s"
           class="btn btn-sm rounded-xl @(isActive ? "btn-primary" : "btn-outline-primary")">
            @s.ToVietnamese()
            <span class="badge rounded-pill @(isActive ? "bg-white bg-opacity-25 text-white" : "bg-light-brown") ms-2">@count</span>
        </a>
    }
</div>

<!-- Table -->
<div class="table-responsive bg-white rounded-2xl border shadow-sm mb-5">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="bg-cream text-muted-custom">
            <tr>
                <th class="px-4 py-3 fw-semibold">Đơn #</th>
                <th class="px-4 py-3 fw-semibold">Khách hàng</th>
                <th class="px-4 py-3 fw-semibold">Sản phẩm</th>
                <th class="px-4 py-3 fw-semibold">Tổng tiền</th>
                <th class="px-4 py-3 fw-semibold">Trạng thái</th>
                <th class="px-4 py-3 fw-semibold">Thời gian</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="px-4 py-5 text-center text-muted-custom">
                        <svg class="mx-auto mb-3 text-caramel" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                        <div>Không có đơn hàng nào.</div>
                    </td>
                </tr>
            }
            @foreach (var order in Model)
            {
                <tr>
                    <td class="px-4 py-3 font-monospace fw-semibold text-coffee">#@order.Id.ToString("D4")</td>
                    <td class="px-4 py-3">
                        <div class="fw-semibold text-coffee">@order.Customer?.FullName</div>
                        <small class="text-muted-custom">@order.Customer?.Phone</small>
                    </td>
                    <td class="px-4 py-3 text-muted-custom small">
                        @string.Join(", ", order.OrderItems.Select(i => $"{i.ProductName} ×{i.Quantity}"))
                    </td>
                    <td class="px-4 py-3 text-end fw-bold text-coffee">@order.TotalAmount.ToString("N0") ₫</td>
                    <td class="px-4 py-3 text-center">
                        <span class="badge @order.Status.ToBadgeClass()">@order.Status.ToVietnamese()</span>
                    </td>
                    <td class="px-4 py-3 text-muted-custom small">@order.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</td>
                    <td class="px-4 py-3 text-end">
                        <a asp-area="Admin" asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-primary rounded-xl">
                            Chi tiết →
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

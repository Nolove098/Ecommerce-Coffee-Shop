@{
    var salesData = new[] {
        new { time = "6 AM", sales = 120 },
        new { time = "8 AM", sales = 450 },
        new { time = "10 AM", sales = 680 },
        new { time = "12 PM", sales = 890 },
        new { time = "2 PM", sales = 720 },
        new { time = "4 PM", sales = 850 },
        new { time = "6 PM", sales = 650 },
        new { time = "8 PM", sales = 320 },
    };
    
    var totalSales = salesData.Sum(x => x.sales);
    var yesterday = totalSales * 0.875; // Tính 12.5% tăng
}

<div class="bg-white p-6 rounded-3xl border border-[#E8DFD8] shadow-sm mt-4">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h3 class="text-lg font-bold  text-[#6F4E37]">Real-Time Sales</h3>
            <p class="text-sm text-[#8B7355] mt-1">Today's performance overview</p>
        </div>
        <div class="text-right">
            <div class="flex items-center gap-2 justify-end">
                <svg class="w-5 h-5 text-[#6F4E37]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-3xl font-bold text-[#6F4E37]">$@totalSales.ToString("N0")</span>
            </div>
            <div class="flex items-center gap-1 text-sm text-green-600 mt-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                <span>+12.5% from yesterday</span>
            </div>
        </div>
    </div>

    <!-- Chart -->
    <div>
    </div>
    <canvas id="salesChart"></canvas>
    <div>
    </div>
</div>
    <script>
        const ctx = document.getElementById('salesChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesData.Select(x => x.time))),
                datasets: [{
                    label: 'Sales',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesData.Select(x => x.sales))),
                    borderColor: '#6F4E37',
                    backgroundColor: 'rgba(212, 165, 116, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: '#D4A574',
                    pointBorderColor: '#6F4E37',
                    pointBorderWidth: 2,
                    pointHoverRadius: 7,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: false,
                    },
                    tooltip: {
                        backgroundColor: 'white',
                        borderColor: '#E8DFD8',
                        borderWidth: 1,
                        titleColor: '#6F4E37',
                        bodyColor: '#6F4E37',
                        padding: 12,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return '$' + context.parsed.y.toLocaleString();
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: '#E8DFD8',
                            drawBorder: false,
                        },
                        ticks: {
                            color: '#8B7355',
                            font: {
                                size: 12
                            },
                            callback: function(value) {
                                return '$' + value;
                            }
                        }
                    },
                    x: {
                        grid: {
                            display: false,
                        },
                        ticks: {
                            color: '#8B7355',
                            font: {
                                size: 12
                            }
                        }
                    }
                }
            }
        });
    </script>


@model SaleStore.Models.Order
@using SaleStore.Models
@{
    ViewData["Title"] = "Đơn hàng #" + (Model?.Id.ToString("D4") ?? "");
    var customerName = Model?.CustomerName ?? Model?.Customer?.FullName;
    var customerInitial = string.IsNullOrEmpty(customerName) ? "?" : customerName[0].ToString();
    // Determine the next logical status
    var nextStatus = Model!.Status switch {
        OrderStatus.Pending   => OrderStatus.Ready,
        OrderStatus.Ready     => OrderStatus.Delivered,
        _ => (OrderStatus?)null
    };
}

<div class="container" style="max-width: 900px;">

    <!-- Header card -->
    <div class="card shadow-soft mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
                <div>
                    <div class="d-flex align-items-center gap-3 mb-1">
                        <h3 class="h5 fw-bold text-coffee mb-0">Đơn #@Model.Id.ToString("D4")</h3>
                        <span class="badge @Model.Status.ToBadgeClass()">@Model.Status.ToVietnamese()</span>
                    </div>
                    <p class="small text-muted-custom mb-0">Đặt lúc: @Model.CreatedAt.AddHours(7).ToString("HH:mm - dd/MM/yyyy")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Customer info -->
        <div class="col-12 col-md-6">
            <div class="card shadow-soft h-100">
                <div class="card-body p-4">
                    <h4 class="small fw-bold text-coffee text-uppercase mb-3">Thông tin khách hàng</h4>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-light-brown rounded-circle d-flex align-items-center justify-content-center fw-bold text-coffee" style="width: 40px; height: 40px;">
                                @customerInitial
                            </div>
                            <div>
                                <p class="fw-semibold text-coffee mb-0">@customerName</p>
                                <p class="small text-muted-custom mb-0">@Model.Customer?.Phone</p>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.TableNumber))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-primary rounded-pill">🪑 Bàn @Model.TableNumber</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="alert alert-warning mb-0 rounded-xl" style="background-color: #FEF3C7; border-color: #FDE68A; color: #92400E;">
                                <strong>Ghi chú:</strong> @Model.Note
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Status timeline (Blazor interactive component) -->
        <div class="col-12 col-md-6">
            <component type="typeof(SaleStore.Components.OrderStatusUpdater)" render-mode="ServerPrerendered"
                       param-OrderId="Model.Id" param-InitialStatus="@Model.Status.ToString()" />
        </div>
    </div>

    <!-- Order items -->
    <div class="card shadow-soft mb-4">
        <div class="card-header bg-cream border-bottom" style="border-color: var(--color-border);">
            <h4 class="small fw-bold text-coffee text-uppercase mb-0">Chi tiết đơn hàng</h4>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light-brown">
                    <tr>
                        <th class="text-start px-4 py-3 fw-semibold text-muted-custom">Sản phẩm</th>
                        <th class="text-center px-4 py-3 fw-semibold text-muted-custom">SL</th>
                        <th class="text-end px-4 py-3 fw-semibold text-muted-custom">Đơn giá</th>
                        <th class="text-end px-4 py-3 fw-semibold text-muted-custom">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td class="px-4 py-3 fw-medium text-coffee">@item.ProductName</td>
                            <td class="px-4 py-3 text-center text-coffee">@item.Quantity</td>
                            <td class="px-4 py-3 text-end text-muted-custom">@item.UnitPrice.ToString("N0") ₫</td>
                            <td class="px-4 py-3 text-end fw-semibold text-coffee">@item.LineTotal.ToString("N0") ₫</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-light-brown">
                    <tr>
                        <td colspan="3" class="px-4 py-3 text-end fw-bold text-coffee">Tổng cộng</td>
                        <td class="px-4 py-3 text-end fw-bold fs-5 text-coffee">@Model.TotalAmount.ToString("N0") ₫</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <!-- Back -->
    <div>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index"
           class="d-inline-flex align-items-center gap-2 small text-coffee text-decoration-none fw-medium">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Quay lại danh sách đơn hàng
        </a>
    </div>

</div>

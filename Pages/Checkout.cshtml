@page "/Pages/Checkout"
@model SaleStore.Pages.CheckoutModel
@{
    Layout = "/Pages/Shared/_PagesLayout.cshtml";
    ViewData["Title"] = "Thanh toán";
}

<!-- Hero Section -->
<section class="bg-gradient-to-r from-[#6F4E37] to-[#2C1810] text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl font-bold mb-2">🛒 Thanh toán</h1>
        <p class="text-gray-300">Hoàn tất đơn hàng của bạn</p>
    </div>
</section>

<!-- Checkout Content -->
<section class="py-12 bg-[#FAF8F5]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @if (TempData["Error"] != null)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
                @TempData["Error"]
            </div>
        }

        @if (Model.CartItems == null || !Model.CartItems.Any())
        {
            <div class="text-center py-12">
                <svg class="w-24 h-24 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 5H19"/>
                </svg>
                <p class="text-gray-500 text-xl mb-4">Giỏ hàng của bạn đang trống</p>
                <a href="/Pages/Menu" class="inline-block bg-[#6F4E37] text-white px-6 py-3 rounded-lg hover:bg-[#5D3A1A] transition">
                    Xem thực đơn
                </a>
            </div>
        }
        else
        {
            <form method="post" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left Column - Customer Info -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Contact Information -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h2 class="text-xl font-bold text-[#2C1810] mb-4">Thông tin liên hệ</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Họ và tên *</label>
                                <input type="text" asp-for="CheckoutInfo.FullName" required
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#6F4E37] focus:border-transparent"/>
                                <span asp-validation-for="CheckoutInfo.FullName" class="text-red-500 text-sm"></span>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Số điện thoại *</label>
                                <input type="tel" asp-for="CheckoutInfo.Phone" required
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#6F4E37] focus:border-transparent"/>
                                <span asp-validation-for="CheckoutInfo.Phone" class="text-red-500 text-sm"></span>
                            </div>
                        </div>
                        <div class="mt-4">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
                            <input type="email" asp-for="CheckoutInfo.Email"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#6F4E37] focus:border-transparent"/>
                        </div>
                    </div>

                    <!-- Shipping Address -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h2 class="text-xl font-bold text-[#2C1810] mb-4">Địa chỉ giao hàng</h2>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Địa chỉ *</label>
                            <textarea asp-for="CheckoutInfo.Address" required rows="3"
                                      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#6F4E37] focus:border-transparent"
                                      placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
                            <span asp-validation-for="CheckoutInfo.Address" class="text-red-500 text-sm"></span>
                        </div>
                        <div class="mt-4">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Ghi chú</label>
                            <textarea asp-for="CheckoutInfo.Note" rows="2"
                                      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#6F4E37] focus:border-transparent"
                                      placeholder="Ghi chú thêm về đơn hàng (tùy chọn)"></textarea>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h2 class="text-xl font-bold text-[#2C1810] mb-4">Phương thức thanh toán</h2>
                        <div class="space-y-3">
                            <label class="flex items-center p-4 border-2 border-gray-200 rounded-lg cursor-pointer hover:border-[#6F4E37] transition">
                                <input type="radio" asp-for="CheckoutInfo.PaymentMethod" value="COD" checked class="w-4 h-4 text-[#6F4E37]"/>
                                <div class="ml-3">
                                    <p class="font-semibold text-gray-800">Thanh toán khi nhận hàng (COD)</p>
                                    <p class="text-sm text-gray-500">Thanh toán bằng tiền mặt khi nhận hàng</p>
                                </div>
                            </label>
                            <label class="flex items-center p-4 border-2 border-gray-200 rounded-lg cursor-pointer hover:border-[#6F4E37] transition opacity-50">
                                <input type="radio" asp-for="CheckoutInfo.PaymentMethod" value="Banking" disabled class="w-4 h-4 text-[#6F4E37]"/>
                                <div class="ml-3">
                                    <p class="font-semibold text-gray-800">Chuyển khoản ngân hàng</p>
                                    <p class="text-sm text-gray-500">Đang phát triển</p>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Order Summary -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-lg shadow-md p-6 sticky top-4">
                        <h2 class="text-xl font-bold text-[#2C1810] mb-4">Đơn hàng của bạn</h2>
                        
                        <!-- Cart Items -->
                        <div class="space-y-3 mb-4 max-h-64 overflow-y-auto">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="flex gap-3 pb-3 border-b border-gray-200">
                                    <div class="w-16 h-16 bg-gray-200 rounded-lg overflow-hidden flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.ProductName" class="w-full h-full object-cover"/>
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center text-2xl">☕</div>
                                        }
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="font-semibold text-sm text-gray-800 truncate">@item.ProductName</h3>
                                        <p class="text-xs text-gray-500">SL: @item.Quantity</p>
                                        <p class="text-[#6F4E37] font-bold text-sm">@((item.Price * item.Quantity).ToString("N0")) ₫</p>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Order Summary -->
                        <div class="space-y-2 py-4 border-t border-gray-200">
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">Tạm tính:</span>
                                <span class="font-semibold">@Model.TotalAmount.ToString("N0") ₫</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">Phí vận chuyển:</span>
                                <span class="font-semibold">@Model.ShippingFee.ToString("N0") ₫</span>
                            </div>
                            <div class="flex justify-between text-lg font-bold pt-2 border-t border-gray-200">
                                <span class="text-gray-800">Tổng cộng:</span>
                                <span class="text-[#6F4E37]">@Model.GrandTotal.ToString("N0") ₫</span>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="w-full bg-[#6F4E37] hover:bg-[#5D3A1A] text-white py-3 rounded-lg font-semibold transition mt-4">
                            Đặt hàng
                        </button>
                        <a href="/Pages/Menu" class="block text-center text-[#6F4E37] hover:text-[#5D3A1A] text-sm mt-3 transition">
                            ← Tiếp tục mua hàng
                        </a>
                    </div>
                </div>
            </form>
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
